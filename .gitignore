config/seo/auto_apply_runtime_override.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Node
node_modules/
.astro/

# Env
.env
.env.local
.env.*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Reports (generated, do not commit; except audit trail)
reports/superparty/seo_level5_status.json
.vercel
.env*.local
