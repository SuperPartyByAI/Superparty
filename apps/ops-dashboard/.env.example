# Ops Dashboard — .env (COPIAZA IN .env SI COMPLETEAZA)

OPS_PORT=8787
OPS_BASE_URL=https://ops.superparty.ro

# Email exact autorizat (doar ursache.andrei1995@gmail.com)
OPS_ALLOWED_EMAILS=ursache.andrei1995@gmail.com

# Google OAuth - din Google Cloud Console
OPS_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
OPS_GOOGLE_CLIENT_SECRET=xxxxxxxx

# Session secret - random lung (min 32 chars)
OPS_SESSION_SECRET=GENEREAZA-UN-SECRET-RANDOM-DE-MINIM-32-CARACTERE

# Paths catre datele SEO (pe server Hetzner)
OPS_REPORTS_DIR=/srv/superparty/reports/superparty
OPS_SEO_REPORTS_DIR=/srv/superparty/reports/seo
OPS_EXPERIMENTS_DB=/srv/superparty/reports/superparty/seo_experiments.db
OPS_MANIFEST_PATH=/srv/superparty/reports/seo/indexing_manifest.json
OPS_SITEMAP_PATH=/srv/superparty/public/sitemap.xml

# Data dir pentru sesiuni SQLite
OPS_DATA_DIR=/srv/ops-dashboard/data

# Node env
NODE_ENV=production
