[Unit]
Description=Superparty SEO Worker (Apply)
After=network.target

[Service]
Type=simple
User=superparty-agent
Group=superparty-agent
WorkingDirectory=/var/www/superparty
EnvironmentFile=/var/www/superparty/.env
ExecStart=/usr/bin/python3 -m agent.services.worker apply
Restart=always
RestartSec=5
StandardOutput=append:/var/www/superparty/logs/worker_apply.log
StandardError=append:/var/www/superparty/logs/worker_apply.log

[Install]
WantedBy=multi-user.target
