---
// FlagshipLink.astro - Banner intern spre pagina flagship
// Folosit pe toate paginile locale pentru a trimite link juice spre
// /animatori-petreceri-copii (pagina principală de ranking)
---

<section class="flagship-link-banner">
  <div class="flagship-inner">
    <div class="flagship-text">
      <p>🎭 Cați animatori și prețuri complete pentru <strong>București & Ilfov</strong>?</p>
    </div>
    <a href="/animatori-petreceri-copii" class="flagship-btn">
      Vezi toate pachetele → Animatori Petreceri Copii București
    </a>
  </div>
</section>

<style>
  .flagship-link-banner {
    background: linear-gradient(135deg, #ebf8ff 0%, #bee3f8 100%);
    border: 1px solid #90cdf4;
    border-radius: 12px;
    padding: 1.25rem 2rem;
    margin: 2rem 0;
  }
  .flagship-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .flagship-text p {
    margin: 0;
    color: #2c5282;
    font-size: 1rem;
  }
  .flagship-btn {
    background: #2b6cb0;
    color: white;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .flagship-btn:hover {
    background: #2c5282;
  }
</style>
