---
export interface Props {
  reviews?: {
    name: string;
    text: string;
    stars: number;
    date: string;
    profileColor: string;
  }[];
  gmbUrl?: string;
}

// Dummy data as requested by the user until GMB URL is tied in.
const defaultReviews = [
  {
    name: "Andreea M.",
    text: "O echipă fantastică! L-am chemat pe Spider-Man pentru băiețelul meu de 5 ani și a fost fenomenal. Copiii au fost extrem de captivați de jocurile pânzei de păianjen. Recomand cu mare drag în zona Sector 3!",
    stars: 5,
    date: "Acum 2 săptămâni",
    profileColor: "bg-blue-500"
  },
  {
    name: "Raluca Popescu",
    text: "Am colaborat pentru un botez și Ursitoarele au fost de o eleganță rară. Vocea suavă, versurile au adus lacrimi în ochii nașilor. Au intrat la fix, nu au deranjat deloc bebelușul. Jos pălăria băieți!",
    stars: 5,
    date: "Acum o lună",
    profileColor: "bg-purple-500"
  },
  {
    name: "Mihai Stoican",
    text: "Elsa a făcut senzație absolută în Pipera. Animatorul chiar era actriță, voce divină la momentul tortului, a făcut face painting foarte repede la toți cei 15 copii invitați! Nota 10.",
    stars: 5,
    date: "Acum 2 luni",
    profileColor: "bg-pink-500"
  }
];

const { reviews = defaultReviews, gmbUrl = "#" } = Astro.props;
---

<div class="w-full bg-white dark:bg-gray-800 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white sm:text-4xl">
        Părinții recomandă Superparty
      </h2>
      <p class="mt-4 text-xl text-gray-500 dark:text-gray-400">
        Review-uri 5 stele de la sute de petreceri memorabile în București și Ilfov.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3 mb-10">
      {reviews.map((review) => (
        <div class="bg-gray-50 dark:bg-gray-900 border border-gray-100 dark:border-gray-700 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow">
          
          <div class="flex items-center mb-4">
            <div class={`h-10 w-10 rounded-full flex items-center justify-center text-white font-bold text-lg ${review.profileColor}`}>
              {review.name.charAt(0)}
            </div>
            <div class="ml-4">
              <h3 class="text-lg font-semibold text-gray-900 dark:text-white leading-none">{review.name}</h3>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">{review.date}</p>
            </div>
          </div>
          
          <div class="flex mb-3">
            {[...Array(review.stars)].map(() => (
              <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <p class="text-gray-600 dark:text-gray-300 italic">
            "{review.text}"
          </p>
          
        </div>
      ))}
    </div>

    <div class="text-center">
      <a 
        href={gmbUrl} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-full text-white bg-blue-600 hover:bg-blue-700 md:py-4 md:text-lg md:px-10 transition-colors shadow-lg hover:shadow-xl"
      >
        <svg class="w-6 h-6 mr-3 bg-white text-blue-600 rounded-full p-1" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12.02 0C5.393 0 .02 5.372.02 11.999c0 5.483 3.652 10.12 8.673 11.59l3.328-9.92L6.16 9.423V5.594h5.86V2.646c0-2.43 1.87-4.417 4.264-4.573V1.67h-4.264c-1.33 0-2.422 1.09-2.422 2.418v1.506h4.502l-.634 3.829h-3.868l2.95 8.796c.485.087.985.132 1.492.132 6.626 0 11.999-5.372 11.999-11.999S18.646 0 12.02 0z" fill="currentColor"/>
        </svg>
        Citește toate recenziile pe Google
      </a>
      <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">Peste 150+ de familii fericite din București au evaluat serviciile noastre.</p>
    </div>

  </div>
</div>
