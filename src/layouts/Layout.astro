---
export interface Props {
  title: string;
  description?: string;
  robots?: string;
  schema?: string;
  canonical?: string;
}
const { title, description = 'SuperParty - Animatori petreceri copii Bucuresti. Personaje costumate, baloane, decoratiuni. Rezerva: 0722 744 377', robots, schema, canonical } = Astro.props;

// GA4 Measurement ID = G-B2HBZK3FQ7 — set in .env: PUBLIC_GA4_ID=G-B2HBZK3FQ7
const GA4_ID = import.meta.env.PUBLIC_GA4_ID || '';
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  {canonical && <link rel="canonical" href={canonical} />}
  {schema && <script type="application/ld+json" set:html={schema} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />

  <!-- Google Analytics 4 -->
  {GA4_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
      <script define:vars={{ GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA4_ID, { send_page_view: true });
        window._gtag = gtag;
      </script>
    </>
  )}
  <style>
    :root {
      --primary: #ff6b35;
      --primary-dark: #e55a25;
      --accent: #ffd700;
      --dark: #0d0d0d;
      --dark-2: #141414;
      --dark-3: #1e1e1e;
      --text: #f0f0f0;
      --text-muted: #a0a0a0;
      --radius: 16px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { overflow-x: hidden; width: 100%; max-width: 100vw; }
    body { font-family: 'Inter', sans-serif; background: var(--dark); color: var(--text); line-height: 1.6; word-wrap: break-word; overflow-wrap: break-word; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(13,13,13,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,107,53,0.2);
      padding: 1rem 0;
    }
    .nav-inner { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); text-decoration: none; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--text-muted); text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: color 0.2s; }
    .nav-links a:hover { color: var(--primary); }
    .nav-cta { background: var(--primary); color: white !important; padding: 0.5rem 1.2rem; border-radius: 50px; }
    .nav-cta:hover { background: var(--primary-dark) !important; color: white !important; }
    footer { background: var(--dark-3); padding: 3rem 0; text-align: center; color: var(--text-muted); border-top: 1px solid rgba(255,107,53,0.15); }
    footer a { color: var(--primary); text-decoration: none; }
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    @keyframes glow { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }
    .whatsapp-float {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 999;
      background: #25d366; color: white; width: 60px; height: 60px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem; box-shadow: 0 4px 20px rgba(37,211,102,0.5);
      text-decoration: none; transition: transform 0.2s;
    }
    .whatsapp-float:hover { transform: scale(1.1); }
    .article-content h2 { color: var(--primary); margin: 2rem 0 1rem; font-size: 1.4rem; }
    .article-content h3 { color: var(--accent); margin: 1.5rem 0 0.75rem; }
    .article-content p { margin-bottom: 1rem; color: var(--text-muted); }
    .article-content ul, .article-content ol { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text-muted); }
    .article-content li { margin-bottom: 0.4rem; }
    .article-content table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    .article-content th { background: rgba(255,107,53,0.2); padding: 0.75rem; text-align: left; }
    .article-content td { padding: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
  </style>
</head>
<body>
  <nav>
    <div class="container nav-inner">
      <a href="/" class="logo">🎉 SuperParty</a>
      <ul class="nav-links">
        <li><a href="/animatori-petreceri-copii/">Animatori</a></li>
        <li><a href="/decoratiuni-baloane/">Baloane</a></li>
        <li><a href="/ursitoare-botez/">Botez</a></li>
        <li><a href="/blog/">Articole</a></li>
        <li><a href="tel:+40722744377" class="nav-cta">📞 0722 744 377</a></li>
      </ul>
    </div>
  </nav>
  <slot />
  <footer>
    <div class="container">
      <p style="font-size:1.5rem; margin-bottom:1rem;">🎉</p>
      <p style="font-weight:700; margin-bottom:0.5rem;">SuperParty — Animatori Petreceri Copii București</p>
      <p style="margin-bottom:1rem;">📞 <a href="tel:+40722744377">0722 744 377</a> &nbsp;|&nbsp; 💬 <a href="https://wa.me/40722744377">WhatsApp</a></p>
      <p style="font-size:0.8rem;">© {new Date().getFullYear()} SuperParty.ro — Toate drepturile rezervate</p>
    </div>
  </footer>
  <a href="https://wa.me/40722744377"
    class="whatsapp-float"
    id="wa-float-btn"
    aria-label="Contacteaza-ne pe WhatsApp">💬</a>

  <!-- GA4 click event tracking -->
  <script>
    (function() {
      function gtag() {
        if (typeof window._gtag === 'function') { window._gtag.apply(null, arguments); }
        else { (window.dataLayer = window.dataLayer||[]).push(arguments); }
      }

      function trackClick(eventName, params) {
        gtag('event', eventName, Object.assign({
          event_category: 'engagement',
          event_label: document.title,
        }, params));
      }

      document.addEventListener('click', function(e) {
        var el = e.target.closest('a, button');
        if (!el) return;
        var href = el.getAttribute('href') || '';
        var text = (el.innerText || el.getAttribute('aria-label') || '').trim().slice(0, 80);

        // Phone call
        if (href.startsWith('tel:')) {
          trackClick('click_to_call', { phone: href, label: text });
        }
        // WhatsApp
        else if (href.includes('wa.me') || href.includes('whatsapp')) {
          trackClick('click_to_whatsapp', { label: text });
        }
        // CTA buttons (rezerva, comanda, etc)
        else if (el.classList.contains('cta') || el.classList.contains('nav-cta') ||
                 el.closest('.hero-ctas') || el.closest('[class*="cta"]')) {
          trackClick('cta_click', { destination: href, label: text });
        }
      });

      // Track scroll depth (25%, 50%, 75%, 90%)
      var depths = [25, 50, 75, 90];
      var fired = {};
      window.addEventListener('scroll', function() {
        var pct = Math.round((window.scrollY + window.innerHeight) / document.body.scrollHeight * 100);
        depths.forEach(function(d) {
          if (pct >= d && !fired[d]) {
            fired[d] = true;
            trackClick('scroll_depth', { percent: d });
          }
        });
      }, { passive: true });

      // Track form submits
      document.addEventListener('submit', function(e) {
        var form = e.target;
        trackClick('form_submit', { form_id: form.id || form.action || 'unknown' });
      });
    })();
  </script>
</body>
</html>
