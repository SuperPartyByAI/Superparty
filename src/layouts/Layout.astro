---
export interface Props {
  title: string;
  description?: string;
  robots?: string;
  schema?: string;
  canonical?: string;
}
const { title, description = 'SuperParty - Animatori petreceri copii Bucuresti. Personaje costumate, baloane, decoratiuni. Rezerva: 0722 744 377', robots, schema, canonical } = Astro.props;

const finalCanonical = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const finalRobots = robots || "index, follow";

const GA4_ID = import.meta.env.PUBLIC_GA4_ID || '';
const WA_TEXT = encodeURIComponent('Bună! Vreau să rezerv animatori pentru petrecerea copilului meu.\nData: \nLocalitate/Sector: \nVârsta copilului: \nNr. copii: \nPachet dorit (opțional): ');
const WA_URL = `https://wa.me/40722744377?text=${WA_TEXT}`;
---
<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={finalRobots} />
  <link rel="canonical" href={finalCanonical} />
  {schema && <script type="application/ld+json" set:html={schema} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" /></noscript>

  <!-- Preload LCP Hero Image for 100/100 Lighthouse -->
  <link rel="preload" href="/wp-content/uploads/generated/hero-coperta.webp" as="image" type="image/webp" />

  <!-- Google Analytics 4 (Optimizat prin Astro Partytown) -->
  {GA4_ID && (
    <>
      <script type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
      <script type="text/partytown" define:vars={{ GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA4_ID, { send_page_view: true });
        window._gtag = gtag;
      </script>
    </>
  )}
  <style>
    :root {
      --primary: #ff6b35;
      --primary-dark: #e55a25;
      --accent: #ffd700;
      --dark: #0d0d0d;
      --dark-2: #141414;
      --dark-3: #1e1e1e;
      --text: #f0f0f0;
      --text-muted: #a0a0a0;
      --radius: 16px;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body { overflow-x: hidden; width: 100%; max-width: 100vw; }
    body { font-family: 'Inter', sans-serif; background: var(--dark); color: var(--text); line-height: 1.6; word-wrap: break-word; overflow-wrap: break-word; }
    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }

    /* ─── NAVIGATION ─── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(13,13,13,0.95);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,107,53,0.2);
      padding: 0.85rem 0;
    }
    .nav-inner { display: flex; justify-content: space-between; align-items: center; }
    .logo { font-size: 1.4rem; font-weight: 800; color: var(--primary); text-decoration: none; letter-spacing: -0.5px; }
    .nav-links { display: flex; gap: 1.5rem; list-style: none; align-items: center; }
    .nav-links a { color: var(--text-muted); text-decoration: none; font-weight: 600; font-size: 0.9rem; transition: color 0.2s; }
    .nav-links a:hover, .nav-links a:focus-visible { color: var(--primary); outline: none; }
    .nav-cta { background: var(--primary) !important; color: white !important; padding: 0.5rem 1.2rem; border-radius: 50px; transition: background 0.2s !important; }
    .nav-cta:hover, .nav-cta:focus-visible { background: var(--primary-dark) !important; }

    /* Hamburger */
    .hamburger {
      display: none; flex-direction: column; gap: 5px; cursor: pointer;
      background: none; border: none; padding: 4px; z-index: 200;
    }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--text); border-radius: 2px; transition: all 0.3s ease; }
    .hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
    .hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Mobile nav drawer */
    .mobile-drawer {
      display: none; position: fixed; inset: 0; top: 0; z-index: 150;
      background: rgba(13,13,13,0.98); padding: 5rem 2rem 2rem;
      flex-direction: column; gap: 2rem;
    }
    .mobile-drawer.open { display: flex; }
    .mobile-drawer a { color: var(--text); text-decoration: none; font-size: 1.4rem; font-weight: 700; border-bottom: 1px solid rgba(255,107,53,0.15); padding-bottom: 1rem; }
    .mobile-drawer a:hover { color: var(--primary); }
    .mobile-drawer .close-btn {
      position: absolute; top: 1.2rem; right: 1.5rem;
      background: none; border: none; color: var(--text); font-size: 2rem; cursor: pointer; line-height: 1;
    }

    /* ─── MOBILE CTA BAR (fixed bottom) ─── */
    .mobile-cta-bar {
      display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 90;
      background: var(--dark-3); border-top: 1px solid rgba(255,107,53,0.25);
      padding: 0.75rem 1rem; gap: 0.75rem;
    }
    .mobile-cta-bar a {
      flex: 1; padding: 0.75rem 0.5rem; border-radius: 12px;
      font-weight: 700; font-size: 0.95rem; text-align: center;
      text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 0.4rem;
    }
    .mobile-cta-call { background: var(--primary); color: white; }
    .mobile-cta-wa { background: #25d366; color: white; }

    /* ─── WHATSAPP FLOAT ─── */
    .whatsapp-float {
      position: fixed; bottom: 5.5rem; right: 1.5rem; z-index: 89;
      background: #25d366; color: white; width: 56px; height: 56px;
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1.6rem; box-shadow: 0 4px 20px rgba(37,211,102,0.4);
      text-decoration: none; transition: transform 0.2s;
    }
    .whatsapp-float:hover { transform: scale(1.1); }

    /* ─── FOOTER ─── */
    footer { background: var(--dark-3); padding: 3rem 0 5rem; text-align: center; color: var(--text-muted); border-top: 1px solid rgba(255,107,53,0.15); }
    footer a { color: var(--primary); text-decoration: none; }
    footer a:hover { text-decoration: underline; }

    /* ─── ARTICLE CONTENT ─── */
    .article-content h2 { color: var(--primary); margin: 2rem 0 1rem; font-size: 1.4rem; }
    .article-content h3 { color: var(--accent); margin: 1.5rem 0 0.75rem; }
    .article-content p { margin-bottom: 1rem; color: var(--text-muted); }
    .article-content ul, .article-content ol { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text-muted); }
    .article-content li { margin-bottom: 0.4rem; }
    .article-content table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; }
    .article-content th { background: rgba(255,107,53,0.2); padding: 0.75rem; text-align: left; }
    .article-content td { padding: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.07); }

    /* ─── KEYFRAMES ─── */
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    @keyframes glow { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 768px) {
      .nav-links { display: none; }
      .hamburger { display: flex; }
      .mobile-cta-bar { display: flex; }
      .whatsapp-float { bottom: 5rem; }
      footer { padding-bottom: 6rem; }
    }
    @media (min-width: 769px) {
      .mobile-drawer { display: none !important; }
    }
  </style>
</head>
<body>
  <nav aria-label="Navigare principală">
    <div class="container nav-inner">
      <a href="/" class="logo">🎉 SuperParty</a>
      <!-- Desktop nav -->
      <ul class="nav-links">
        <li><a href="/animatori-petreceri-copii/">Animatori</a></li>
        <li><a href="/decoratiuni-baloane/">Baloane</a></li>
        <li><a href="/ursitoare-botez/">Botez</a></li>
        <li><a href="/ghid/" style="color:#F97316;font-weight:700">Ghid Părinți</a></li>
        <li><a href="/recenzii/">Recenzii</a></li>
        <li><a href="/arie-acoperire/">Zone</a></li>
        <li><a href="tel:+40722744377" class="nav-cta">📞 0722 744 377</a></li>
      </ul>
      <!-- Hamburger button (mobile) -->
      <button class="hamburger" id="hamburger-btn" aria-expanded="false" aria-controls="mobile-drawer" aria-label="Deschide meniu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <nav class="mobile-drawer" id="mobile-drawer" aria-label="Meniu mobil">
    <button class="close-btn" id="close-drawer" aria-label="Închide meniu">✕</button>
    <a href="/animatori-petreceri-copii/">🎪 Animatori</a>
    <a href="/decoratiuni-baloane/">🎈 Baloane</a>
    <a href="/ursitoare-botez/">🍼 Botez</a>
    <a href="/ghid/" style="color:#F97316">📚 Ghid Părinți</a>
    <a href="/recenzii/">⭐ Recenzii</a>
    <a href="/arie-acoperire/">📍 Zone Acoperite</a>
    <a href="/contact/">📧 Contact</a>
  </nav>

  <slot />

  <footer>
    <div class="container">
      <p style="font-size:1.5rem; margin-bottom:1rem;">🎉</p>
      <p style="font-weight:700; margin-bottom:0.5rem;">SuperParty — Animatori Petreceri Copii București</p>
      <p style="margin-bottom:0.75rem;">📞 <a href="tel:+40722744377">0722 744 377</a> &nbsp;|&nbsp; 💬 <a href={WA_URL}>WhatsApp</a></p>
      <p style="margin-bottom:0.75rem; font-size:0.9rem; color:var(--text-muted);">
        <a href="/animatori-petreceri-copii/">Animatori</a> ·
        <a href="/arie-acoperire/">Arie Acoperire</a> ·
        <a href="/recenzii/">Recenzii</a> ·
        <a href="/contact/">Contact</a>
      </p>
      <p style="font-size:0.8rem;">© {new Date().getFullYear()} SuperParty.ro — Toate drepturile rezervate</p>
    </div>
  </footer>

  <!-- WhatsApp float (desktop) + mobile CTA bar -->
  <a href={WA_URL}
    class="whatsapp-float"
    id="wa-float-btn"
    aria-label="Contactează-ne pe WhatsApp cu mesaj precompletat"
    target="_blank" rel="noopener noreferrer">💬</a>

  <div class="mobile-cta-bar" role="complementary" aria-label="Quick CTA">
    <a href="tel:+40722744377" class="mobile-cta-call" aria-label="Sună acum">📞 Sună acum</a>
    <a href={WA_URL} class="mobile-cta-wa" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp cu mesaj precompletat">💬 WhatsApp</a>
  </div>

  <!-- Hamburger toggle JS -->
  <script type="module">
    (function() {
      var btn = document.getElementById('hamburger-btn');
      var drawer = document.getElementById('mobile-drawer');
      var closeBtn = document.getElementById('close-drawer');
      function openDrawer() {
        drawer.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeDrawer() {
        drawer.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }
      if (btn) btn.addEventListener('click', openDrawer);
      if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
      if (drawer) drawer.addEventListener('click', function(e) {
        if (e.target === drawer) closeDrawer();
      });
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeDrawer();
      });
    })();
  </script>

  <!-- GA4 event tracking -->
  <script type="module">
    (function() {
      function gtag() {
        if (typeof window._gtag === 'function') { window._gtag.apply(null, arguments); }
        else { (window.dataLayer = window.dataLayer||[]).push(arguments); }
      }
      function trackClick(eventName, params) {
        gtag('event', eventName, Object.assign({ event_category: 'engagement', event_label: document.title }, params));
      }
      document.addEventListener('click', function(e) {
        var el = e.target.closest('a, button');
        if (!el) return;
        var href = el.getAttribute('href') || '';
        var text = (el.innerText || el.getAttribute('aria-label') || '').trim().slice(0, 80);
        if (href.startsWith('tel:')) trackClick('click_to_call', { phone: href, label: text });
        else if (href.includes('wa.me') || href.includes('whatsapp')) trackClick('click_to_whatsapp', { label: text });
        else if (el.classList.contains('cta') || el.classList.contains('nav-cta') || el.closest('.hero-ctas') || el.closest('[class*="cta"]')) {
          trackClick('cta_click', { destination: href, label: text });
        }
      });
      var depths = [25, 50, 75, 90], fired = {};
      window.addEventListener('scroll', function() {
        var pct = Math.round((window.scrollY + window.innerHeight) / document.body.scrollHeight * 100);
        depths.forEach(function(d) { if (pct >= d && !fired[d]) { fired[d] = true; trackClick('scroll_depth', { percent: d }); } });
      }, { passive: true });
      document.addEventListener('submit', function(e) {
        trackClick('form_submit', { form_id: e.target.id || e.target.action || 'unknown' });
      });
    })();
  </script>
</body>
</html>
