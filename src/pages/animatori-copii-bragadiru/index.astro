      <div class="bg-white dark:bg-gray-800 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-gray-700">
        <div class="text-purple-600 dark:text-purple-400 font-semibold mb-3 flex items-center">Top Parcuri Recomandate</div>
        <ul class="text-sm text-gray-600 dark:text-gray-300 space-y-2">
<li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Parcul Bragadiru</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Zonele Cartierului Latin</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Spațiile noi amenajate</span></li>        </ul>
