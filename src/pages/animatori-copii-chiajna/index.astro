<li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Promenada Lacul Morii</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Parcurile din Militari Residence</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Spațiile publice Dudu</span></li>        </ul>
