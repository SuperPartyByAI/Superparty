<li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Parcul Central Otopeni</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Zonele verzi adiacente</span></li><li class="flex items-start"><span class="text-purple-500 mr-2">✓</span><span>Baze sportive</span></li>        </ul>
