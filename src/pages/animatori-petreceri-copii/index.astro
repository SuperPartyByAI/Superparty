        { "@type": "Offer", "name": "Super 7 – 1 Personaj 3 ore + 4 Ursitoare botez", "price": "1290", "priceCurrency": "RON" }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Cât costă un animator pentru petrecere copii?",
          "acceptedAnswer": { "@type": "Answer", "text": "Prețurile pornesc de la 490 RON pentru pachetul Super 1 (1 personaj, 2 ore). Fiecare oră sau personaj extra costă +170 lei. Contactați-ne pentru o ofertă personalizată." }
        },
        {
          "@type": "Question",
          "name": "De la ce vârstă este potrivit un animator?",
          "acceptedAnswer": { "@type": "Answer", "text": "Animatorii noștri lucrează cu copii de la 2 la 12 ani. Programul este adaptat vârstei — jocuri simple pentru cei mici, provocări și ateliere pentru cei mari." }
        },
        {
          "@type": "Question",
          "name": "Cât timp durează o petrecere cu animator?",
          "acceptedAnswer": { "@type": "Answer", "text": "Pachetele noastre sunt de 1, 2 sau 3 ore. Cel mai popular este Super 3 — 2 personaje timp de 2 ore + confetti party." }
        },
        {
          "@type": "Question",
          "name": "Se poate organiza la domiciliu?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da — venim la domiciliu, la sala de petreceri sau la grădiniță/școală. Avem nevoie de un spațiu minim de 15–20 mp pentru activități." }
        },
        {
          "@type": "Question",
          "name": "Cu cât timp înainte trebuie rezervat animatorul?",
          "acceptedAnswer": { "@type": "Answer", "text": "Recomandăm rezervarea cu minimum 7–14 zile înainte, în special în weekend. În perioadele aglomerate (mai–septembrie) rezervați cât mai devreme." }
        },
        {
          "@type": "Question",
          "name": "Ce se întâmplă dacă anulăm?",
          "acceptedAnswer": { "@type": "Answer", "text": "Anulările cu mai mult de 72 de ore înainte nu sunt penalizate. Contactați-ne imediat pentru reprogramare." }
        },
        {
          "@type": "Question",
          "name": "Activați și în Ilfov sau doar în București?",
          "acceptedAnswer": { "@type": "Answer", "text": "Activăm în toată zona București-Ilfov și în localități din raza de ~100 km. Transportul în București este gratuit; pentru Ilfov și 100 km contactați-ne pentru detalii." }
        },
        {
          "@type": "Question",
          "name": "Ce personaje sunt disponibile?",
          "acceptedAnswer": { "@type": "Answer", "text": "Avem peste 30 de personaje: Elsa, Spiderman, PAW Patrol, Ladybug, Batman, Peppa Pig, Rapunzel, Moana, Pikachu, Mickey Mouse, Aurora, Cenușăreasa și multe altele." }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Acasă", "item": "https://www.superparty.ro" },
        { "@type": "ListItem", "position": 2, "name": "Animatori Petreceri Copii", "item": "https://www.superparty.ro/animatori-petreceri-copii" }
      ]
    }
  ]
});

