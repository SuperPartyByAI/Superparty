---
import Layout from '../../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "SuperParty",
      "url": "https://superparty.ro",
      "telephone": "+40722744377",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "București",
        "addressRegion": "Ilfov",
        "addressCountry": "RO"
      },
      "areaServed": ["București", "Ilfov", "Sector 1", "Sector 2", "Sector 3", "Sector 4", "Sector 5", "Sector 6"],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "reviewCount": "80"
      }
    },
    {
      "@type": "Service",
      "name": "Animatori Petreceri Copii București",
      "provider": { "@type": "LocalBusiness", "name": "SuperParty" },
      "areaServed": "București și Ilfov",
      "description": "Animatori profesioniști cu costume premium pentru petreceri copii — personaje Disney, supereroi, eroi animați. Programe structurate 60–120 min.",
      "serviceType": "Animație pentru copii",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "350",
        "highPrice": "750",
        "priceCurrency": "RON"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Cât costă un animator pentru petrecere copii?",
          "acceptedAnswer": { "@type": "Answer", "text": "Prețurile pornesc de la 350 RON pentru 60 de minute și variază în funcție de distanță, număr animatori și personaj. Contactați-ne pentru o ofertă personalizată." }
        },
        {
          "@type": "Question",
          "name": "De la ce vârstă este potrivit un animator?",
          "acceptedAnswer": { "@type": "Answer", "text": "Animatorii noștri lucrează cu copii de la 2 la 12 ani. Programul este adaptat vârstei — jocuri simple pentru cei mici, provocări și ateliere pentru cei mari." }
        },
        {
          "@type": "Question",
          "name": "Cât timp durează o petrecere cu animator?",
          "acceptedAnswer": { "@type": "Answer", "text": "Pachetele standard sunt de 60, 90 sau 120 de minute. Recomandăm 90 de minute pentru petreceri de zi de naștere." }
        },
        {
          "@type": "Question",
          "name": "Se poate organiza la domiciliu?",
          "acceptedAnswer": { "@type": "Answer", "text": "Da — venim la domiciliu, la sala de petreceri sau la grădiniță/școală. Avem nevoie de un spațiu minim de 15–20 mp pentru activități." }
        },
        {
          "@type": "Question",
          "name": "Cu cât timp înainte trebuie rezervat animatorul?",
          "acceptedAnswer": { "@type": "Answer", "text": "Recomandăm rezervarea cu minimum 7–14 zile înainte, în special în weekend. În perioadele aglomerate (mai–septembrie) rezervați cât mai devreme." }
        },
        {
          "@type": "Question",
          "name": "Ce se întâmplă dacă anulăm?",
          "acceptedAnswer": { "@type": "Answer", "text": "Anulările cu mai mult de 72 de ore înainte nu sunt penalizate. Contactați-ne imediat pentru reprogramare." }
        },
        {
          "@type": "Question",
          "name": "Activați și în Ilfov sau doar în București?",
          "acceptedAnswer": { "@type": "Answer", "text": "Activăm în toată zona București-Ilfov și în localități din raza de ~100 km. Contactați-ne cu locația exactă pentru confirmare și eventuala taxă de deplasare." }
        },
        {
          "@type": "Question",
          "name": "Ce personaje sunt disponibile?",
          "acceptedAnswer": { "@type": "Answer", "text": "Avem peste 30 de personaje: Elsa, Spiderman, PAW Patrol, Ladybug, Batman, Peppa Pig, Rapunzel, Moana, Pikachu, Mickey Mouse, Aurora, Cenușăreasa și multe altele. Contactați-ne pentru lista completă." }
        }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Acasă", "item": "https://superparty.ro" },
        { "@type": "ListItem", "position": 2, "name": "Animatori Petreceri Copii", "item": "https://superparty.ro/animatori-petreceri-copii" }
      ]
    }
  ]
});

const personaje = [
  { emoji: '❄️', name: 'Elsa Frozen', slug: 'animator-elsa-frozen-petreceri-copii-bucuresti' },
  { emoji: '🕷️', name: 'Spiderman', slug: 'animator-spiderman-petreceri-copii-bucuresti' },
  { emoji: '🐕', name: 'PAW Patrol', slug: 'animator-paw-patrol-petreceri-copii-bucuresti' },
  { emoji: '🐞', name: 'Ladybug', slug: 'animator-ladybug-petreceri-copii-bucuresti' },
  { emoji: '🦇', name: 'Batman', slug: 'animator-batman-petreceri-copii-bucuresti' },
  { emoji: '🐷', name: 'Peppa Pig', slug: 'animator-peppa-pig-petreceri-copii-bucuresti' },
  { emoji: '💜', name: 'Rapunzel', slug: 'animator-rapunzel-petreceri-copii-bucuresti' },
  { emoji: '🌺', name: 'Moana', slug: 'animator-moana-petreceri-copii-bucuresti' },
  { emoji: '⚡', name: 'Pikachu', slug: 'animator-pikachu-petreceri-copii-bucuresti' },
  { emoji: '🎩', name: 'Mickey Mouse', slug: 'animator-mickey-mouse-petreceri-copii-bucuresti' },
  { emoji: '👸', name: 'Aurora', slug: 'animator-aurora-frumoasa-adormita-petreceri-copii' },
  { emoji: '🏰', name: 'Cenușăreasa', slug: 'animator-cenusareasa-petreceri-copii-bucuresti' },
];

const pachete = [
  {
    name: 'Standard',
    durata: '60 min',
    price: 'de la 350 RON',
    culoare: 'rgba(255,107,53,0.15)',
    border: 'rgba(255,107,53,0.4)',
    include: ['1 animator în costum premium', 'Jocuri interactive adaptate vârstei', 'Dansuri și activități distractive', 'Servire tort + cântec Feliz'],
  },
  {
    name: 'Premium',
    durata: '90 min',
    price: 'de la 500 RON',
    culoare: 'rgba(255,215,0,0.12)',
    border: 'rgba(255,215,0,0.5)',
    badge: '⭐ Cel mai ales',
    include: ['1 animator în costum premium', 'Jocuri + atelier creativ (desen, origami)', 'Mini-spectacol de teatru', 'Baloane modelate la cerere', 'Servire tort + cântec Feliz'],
  },
  {
    name: 'VIP',
    durata: '120 min',
    price: 'de la 700 RON',
    culoare: 'rgba(255,107,53,0.1)',
    border: 'rgba(255,107,53,0.3)',
    include: ['2 animatori în costume premium', 'Program complet personalizat', 'Jocuri + spectacol + dans', 'Baloane modelate + decorațiuni simple', 'Sesiune foto în costume', 'Servire tort + surprize finale'],
  },
];

const faq = [
  { q: 'Cât costă un animator pentru petrecere copii?', a: 'Prețurile pornesc de la 350 RON pentru 60 min. Variază în funcție de distanță, număr de animatori și pachet ales.' },
  { q: 'De la ce vârstă este potrivit?', a: 'De la 2 la 12 ani. Programul este adaptat — jocuri simple pentru cei mici, provocări și ateliere pentru cei mari.' },
  { q: 'Cât durează o petrecere cu animator?', a: '60, 90 sau 120 de minute. Recomandăm 90 min pentru o zi de naștere completă.' },
  { q: 'Se poate organiza la domiciliu?', a: 'Da — la domiciliu, sală de petreceri sau grădiniță. Avem nevoie de minim 15–20 mp pentru activități.' },
  { q: 'Cu cât timp înainte rezervăm?', a: 'Minim 7–14 zile înainte. În sezon (mai–sept) rezervați cât mai devreme.' },
  { q: 'Activați și în Ilfov / 100 km?', a: 'Da — toată zona București-Ilfov și ~100 km. Contactați-ne pentru confirmare și taxa de deplasare.' },
  { q: 'Ce facem dacă anulăm?', a: 'Anulările cu 72+ ore înainte nu sunt penalizate. Contactați-ne imediat pentru reprogramare.' },
  { q: 'Ce personaje aveți disponibile?', a: 'Peste 30 de personaje: Elsa, Spiderman, PAW Patrol, Ladybug, Batman, Peppa Pig, Rapunzel și multe altele.' },
];

const zone = [
  { name: 'Sector 1', href: '/petreceri/sector-1', desc: 'Dorobanți, Floreasca, Aviatorilor' },
  { name: 'Sector 2', href: '/petreceri/sector-2', desc: 'Colentina, Pantelimon, Iancului' },
  { name: 'Sector 3', href: '/petreceri/sector-3', desc: 'Titan, Vitan, Dristor, Balta Albă' },
  { name: 'Sector 4', href: '/petreceri/sector-4', desc: 'Berceni, Olteniței, Giurgiului' },
  { name: 'Sector 5', href: '/petreceri/sector-5', desc: 'Rahova, Ferentari, 13 Septembrie' },
  { name: 'Sector 6', href: '/petreceri/sector-6', desc: 'Militari, Drumul Taberei, Crângași' },
  { name: 'Ilfov', href: '/petreceri/ilfov', desc: 'Voluntari, Otopeni, Bragadiru, Chiajna' },
  { name: 'București', href: '/petreceri/bucuresti', desc: 'Toată capitala, orice zonă' },
];
---

<Layout
  title="Animatori Petreceri Copii București | SuperParty — Personaje Premium"
  description="Animatori profesioniști pentru petreceri copii în București și Ilfov. Costume premium Elsa, Spiderman, PAW Patrol. Pachete 60–120 min. Rezervă acum: 0722 744 377."
  canonical="https://superparty.ro/animatori-petreceri-copii"
  robots="index, follow"
  schema={schema}
>

<style>
  .pilon-hero { padding: 5rem 0 3rem; background: radial-gradient(ellipse at top, rgba(255,107,53,0.12) 0%, transparent 60%); }
  .pilon-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.2; margin-bottom: 1.2rem; }
  .pilon-hero p.lead { font-size: 1.15rem; color: var(--text-muted); max-width: 640px; margin-bottom: 2rem; line-height: 1.8; }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; padding: 1rem 2.2rem; border-radius: 50px; font-weight: 700; font-size: 1.05rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: transform .2s, box-shadow .2s; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,53,.45); }
  .btn-wa { background: #25d366; color: #fff; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; font-size: 1.05rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: transform .2s; }
  .btn-wa:hover { transform: translateY(-2px); }
  .trust-bar { display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 2.5rem; }
  .trust-item { display: flex; align-items: center; gap: .6rem; font-size: .95rem; color: var(--text-muted); font-weight: 600; }
  section.pilon-section { padding: 4rem 0; }
  .section-title { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
  .section-sub { color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.05rem; }
  /* De ce noi */
  .dif-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 1.5rem; }
  .dif-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.15); border-radius: 16px; padding: 1.5rem; }
  .dif-card .icon { font-size: 2rem; margin-bottom: .75rem; }
  .dif-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: .5rem; }
  .dif-card p { font-size: .9rem; color: var(--text-muted); line-height: 1.6; }
  /* Pachete */
  .pachete-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap: 1.5rem; }
  .pachet-card { border-radius: 20px; padding: 2rem; position: relative; transition: transform .2s; }
  .pachet-card:hover { transform: translateY(-4px); }
  .badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--accent); color: #000; font-size: .78rem; font-weight: 700; padding: .3rem .9rem; border-radius: 50px; white-space: nowrap; }
  .pachet-name { font-size: 1.3rem; font-weight: 800; margin-bottom: .3rem; }
  .pachet-durata { color: var(--text-muted); font-size: .9rem; margin-bottom: 1rem; }
  .pachet-price { font-size: 1.5rem; font-weight: 800; color: var(--primary); margin-bottom: 1.5rem; }
  .pachet-include { list-style: none; padding: 0; margin: 0; }
  .pachet-include li { padding: .4rem 0; border-bottom: 1px solid rgba(255,255,255,.06); font-size: .9rem; color: var(--text-muted); display: flex; align-items: flex-start; gap: .5rem; }
  .pachet-include li::before { content: '✓'; color: var(--primary); font-weight: 700; flex-shrink: 0; }
  /* Program */
  .program-steps { display: flex; flex-direction: column; gap: 1rem; max-width: 560px; }
  .prog-step { display: flex; gap: 1.2rem; align-items: flex-start; }
  .prog-dot { width: 42px; height: 42px; border-radius: 50%; background: rgba(255,107,53,.18); border: 2px solid var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--primary); flex-shrink: 0; font-size: .85rem; }
  .prog-content h4 { font-weight: 700; margin-bottom: .2rem; }
  .prog-content p { font-size: .9rem; color: var(--text-muted); }
  /* Personaje */
  .pers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); gap: 1rem; }
  .pers-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.15); border-radius: 14px; padding: 1.2rem; text-align: center; text-decoration: none; color: var(--text); transition: border-color .2s, transform .2s; }
  .pers-card:hover { border-color: var(--primary); transform: translateY(-3px); }
  .pers-card .pers-emoji { font-size: 2.2rem; margin-bottom: .5rem; }
  .pers-card .pers-name { font-size: .9rem; font-weight: 600; }
  /* Zone */
  .zone-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 1rem; }
  .zone-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.12); border-radius: 14px; padding: 1.2rem; text-decoration: none; color: var(--text); transition: border-color .2s; }
  .zone-card:hover { border-color: var(--primary); }
  .zone-card h3 { font-weight: 700; margin-bottom: .3rem; font-size: 1rem; }
  .zone-card p { font-size: .82rem; color: var(--text-muted); }
  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
  .faq-item { background: var(--dark-3); border: 1px solid rgba(255,107,53,.12); border-radius: 14px; padding: 1.4rem; }
  .faq-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: .6rem; }
  .faq-item p { font-size: .93rem; color: var(--text-muted); line-height: 1.7; }
  /* CTA final */
  .cta-final { background: linear-gradient(135deg, rgba(255,107,53,.15), rgba(255,107,53,.05)); border: 1px solid rgba(255,107,53,.25); border-radius: 24px; padding: 3.5rem 2rem; text-align: center; }
  .cta-final h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
  .cta-final p { color: var(--text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .sep { height: 1px; background: rgba(255,107,53,.12); margin: 1rem 0; }
  @media(max-width:600px) { .hero-ctas { flex-direction: column; } .trust-bar { gap: 1rem; } }
</style>

<!-- ═══════════════════════════════════ HERO ═══════════════════════════════════ -->
<section class="pilon-hero">
  <div class="container">
    <h1>Animatori <span style="color:var(--primary)">Petreceri Copii</span><br>București și Ilfov</h1>
    <p class="lead">Facem ziua de naștere a copilului tău de neuitat — animatori actori în costume premium, programe structurate de jocuri, teatru și surprize. Activi în toată zona București-Ilfov și până la ~100 km.</p>
    <div class="hero-ctas">
      <a href="tel:+40722744377" class="btn-primary cta">📞 Rezervă: 0722 744 377</a>
      <a href="https://wa.me/40722744377?text=Buna%20ziua%2C%20vreau%20sa%20rezerv%20un%20animator%20petreceri%20copii" class="btn-wa cta">💬 WhatsApp</a>
    </div>
    <div class="trust-bar">
      <span class="trust-item">⭐ 5/5 din 80+ recenzii</span>
      <span class="trust-item">✅ Activi din 2019</span>
      <span class="trust-item">🎭 30+ personaje disponibile</span>
      <span class="trust-item">📍 București + Ilfov + ~100 km</span>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ DE CE NOI ═══════════════════════════════════ -->
<section class="pilon-section" style="background:var(--dark-2)">
  <div class="container">
    <h2 class="section-title">De ce aleg părinții <span style="color:var(--primary)">SuperParty</span>?</h2>
    <p class="section-sub">Nu suntem simpli animatori — suntem actori profesioniști care trăiesc personajul.</p>
    <div class="dif-grid">
      <div class="dif-card">
        <div class="icon">🎭</div>
        <h3>Actori cu experiență</h3>
        <p>Nu studenți fără experiență — animatorii noștri au pregătire de actor și știu să capteze atenția copiilor indiferent de vârstă.</p>
      </div>
      <div class="dif-card">
        <div class="icon">👗</div>
        <h3>Costume premium</h3>
        <p>Costume de calitate superioară, identice cu personajele originale. Copiii nu pot face diferența față de „cel adevărat".</p>
      </div>
      <div class="dif-card">
        <div class="icon">⏰</div>
        <h3>Punctualitate garantată</h3>
        <p>Sosim cu 10 min înainte de program. Nu există scuze — petrecerea începe la ora stabilită.</p>
      </div>
      <div class="dif-card">
        <div class="icon">🎯</div>
        <h3>Program personalizat</h3>
        <p>Adaptăm jocurile și activitățile în funcție de vârsta copilului, spațiul disponibil și temă.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ PACHETE ═══════════════════════════════════ -->
<section class="pilon-section">
  <div class="container">
    <h2 class="section-title">Pachete și <span style="color:var(--primary)">Prețuri</span></h2>
    <p class="section-sub">Alegeți pachetul potrivit. Toate includ animatorul în costum + program structurat.</p>
    <div class="pachete-grid">
      {pachete.map(p => (
        <div class="pachet-card" style={`background:${p.culoare}; border: 1px solid ${p.border};`}>
          {p.badge && <span class="badge">{p.badge}</span>}
          <div class="pachet-name">{p.name}</div>
          <div class="pachet-durata">⏱ {p.durata}</div>
          <div class="pachet-price">{p.price}</div>
          <ul class="pachet-include">
            {p.include.map(item => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
    <p style="margin-top:1.5rem; color:var(--text-muted); font-size:.9rem;">
      * Prețurile pot varia în funcție de locație și disponibilitate. Contactați-ne pentru o ofertă exactă.
    </p>
    <div style="margin-top:2rem;">
      <a href="tel:+40722744377" class="btn-primary cta">📞 Cere ofertă gratuită</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ PROGRAM ═══════════════════════════════════ -->
<section class="pilon-section" style="background:var(--dark-2)">
  <div class="container">
    <h2 class="section-title">Cum decurge <span style="color:var(--primary)">petrecerea</span>?</h2>
    <p class="section-sub">Program orientativ pentru pachetul de 90 de minute:</p>
    <div class="program-steps">
      <div class="prog-step">
        <div class="prog-dot">0</div>
        <div class="prog-content">
          <h4>Sosire și pregătire</h4>
          <p>Animatorul sosește cu 10 min înainte, se pregătește în costum și cunoaște spațiul.</p>
        </div>
      </div>
      <div class="prog-step">
        <div class="prog-dot">10'</div>
        <div class="prog-content">
          <h4>Intrare în personaj + surprise</h4>
          <p>Intrare spectaculoasă a personajului, surpriză pentru copii, prezentare și interacțiune.</p>
        </div>
      </div>
      <div class="prog-step">
        <div class="prog-dot">25'</div>
        <div class="prog-content">
          <h4>Jocuri interactive</h4>
          <p>3–5 jocuri adaptate vârstei: mișcare, quiz, dans, provocări distractive.</p>
        </div>
      </div>
      <div class="prog-step">
        <div class="prog-dot">55'</div>
        <div class="prog-content">
          <h4>Atelier creativ / mini-spectacol</h4>
          <p>Desen, origami sau scurtă piesă de teatru cu toți copiii ca actori.</p>
        </div>
      </div>
      <div class="prog-step">
        <div class="prog-dot">80'</div>
        <div class="prog-content">
          <h4>Cântec + tort + final</h4>
          <p>„La mulți ani!" cu personajul, servire tort, sesiune foto în costume și rămas-bun.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════ PERSONAJE ═══════════════════════════════════ -->
<section class="pilon-section">
  <div class="container">
    <h2 class="section-title">Personajele <span style="color:var(--primary)">noastre</span></h2>
    <p class="section-sub">Peste 30 de personaje disponibile. Alege-l pe cel preferat al copilului tău.</p>
    <div class="pers-grid">
      {personaje.map(p => (
        <a href={`/petreceri/${p.slug}`} class="pers-card">
          <div class="pers-emoji">{p.emoji}</div>
          <div class="pers-name">{p.name}</div>
        </a>
      ))}
    </div>
    <p style="margin-top:1.5rem; color:var(--text-muted); font-size:.9rem;">
