---

<Layout
  title="Animatori Petreceri Copii București | SuperParty — Pachete de la 490 lei"
  description="Animatori petreceri copii București - 30 personaje, costume premium. Pachete 490-1290 lei, transport gratuit. Jocuri, baloane, pictură pe față. Rezervă: 0722 744 377."
  canonical="https://www.superparty.ro/animatori-petreceri-copii"
  robots="index, follow"
  schema={schema}
>

<style>
  .pilon-hero { padding: 5rem 0 3rem; background: radial-gradient(ellipse at top, rgba(255,107,53,0.12) 0%, transparent 60%); }
  .pilon-hero h1 { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.2; margin-bottom: 1.2rem; }
  .pilon-hero p.lead { font-size: 1.15rem; color: var(--text-muted); max-width: 640px; margin-bottom: 2rem; line-height: 1.8; }
  .hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: #fff; padding: 1rem 2.2rem; border-radius: 50px; font-weight: 700; font-size: 1.05rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: transform .2s, box-shadow .2s; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,107,53,.45); }
  .btn-wa { background: #25d366; color: #fff; padding: 1rem 2rem; border-radius: 50px; font-weight: 700; font-size: 1.05rem; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: transform .2s; }
  .btn-wa:hover { transform: translateY(-2px); }
  section.pilon-section { padding: 4rem 0; }
  section.pilon-section-alt { padding: 4rem 0; background: var(--dark-2); }
  .section-title { font-size: 1.8rem; font-weight: 800; margin-bottom: 0.5rem; }
  .section-sub { color: var(--text-muted); margin-bottom: 2.5rem; font-size: 1.05rem; }
  /* De ce noi */
  .dif-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px,1fr)); gap: 1.5rem; }
  .dif-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.15); border-radius: 16px; padding: 1.5rem; }
  .dif-card .icon { font-size: 2rem; margin-bottom: .75rem; }
  .dif-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: .5rem; }
  .dif-card p { font-size: .9rem; color: var(--text-muted); line-height: 1.6; }
  /* Pachete */
  .pachete-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px,1fr)); gap: 1.5rem; }
  .pachet-card { border-radius: 20px; padding: 2rem; position: relative; transition: transform .2s; }
  .pachet-card:hover { transform: translateY(-4px); }
  .badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--accent); color: #000; font-size: .78rem; font-weight: 700; padding: .3rem .9rem; border-radius: 50px; white-space: nowrap; }
  .pachet-name { font-size: 1.2rem; font-weight: 800; margin-bottom: .2rem; }
  .pachet-subtitle { color: var(--text-muted); font-size: .88rem; margin-bottom: .4rem; }
  .pachet-conditii { background: rgba(255,215,0,.12); border: 1px solid rgba(255,215,0,.3); border-radius: 6px; padding: .3rem .6rem; font-size: .8rem; color: var(--accent); display: inline-block; margin-bottom: .8rem; }
  .pachet-price { font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 1.2rem; }
  .pachet-price span { font-size: 1rem; font-weight: 600; color: var(--text-muted); }
  .pachet-include { list-style: none; padding: 0; margin: 0 0 1rem; }
  .pachet-include li { padding: .35rem 0; border-bottom: 1px solid rgba(255,255,255,.06); font-size: .88rem; color: var(--text-muted); display: flex; align-items: flex-start; gap: .5rem; }
  .pachet-include li::before { content: '✓'; color: var(--primary); font-weight: 700; flex-shrink: 0; }
  .pachet-extra { font-size: .8rem; color: var(--text-muted); font-style: italic; padding-top: .5rem; border-top: 1px solid rgba(255,255,255,.06); }
  /* Program */
  .program-steps { display: flex; flex-direction: column; gap: 1rem; max-width: 560px; }
  .prog-step { display: flex; gap: 1.2rem; align-items: flex-start; }
  .prog-dot { width: 42px; height: 42px; border-radius: 50%; background: rgba(255,107,53,.18); border: 2px solid var(--primary); display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--primary); flex-shrink: 0; font-size: .85rem; }
  .prog-content h4 { font-weight: 700; margin-bottom: .2rem; }
  .prog-content p { font-size: .9rem; color: var(--text-muted); }
  /* Personaje */
  .pers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px,1fr)); gap: 1rem; }
  .pers-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.15); border-radius: 14px; padding: 1.2rem; text-align: center; text-decoration: none; color: var(--text); transition: border-color .2s, transform .2s; }
  .pers-card:hover { border-color: var(--primary); transform: translateY(-3px); }
  .pers-card .pers-emoji { font-size: 2.2rem; margin-bottom: .5rem; }
  .pers-card .pers-name { font-size: .9rem; font-weight: 600; }
  /* Zone */
  .zone-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr)); gap: 1rem; }
  .zone-card { background: var(--dark-3); border: 1px solid rgba(255,107,53,.12); border-radius: 14px; padding: 1.2rem; text-decoration: none; color: var(--text); transition: border-color .2s; }
  .zone-card:hover { border-color: var(--primary); }
  .zone-card h3 { font-weight: 700; margin-bottom: .3rem; font-size: 1rem; }
  .zone-card p { font-size: .82rem; color: var(--text-muted); }
  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 1rem; max-width: 760px; }
  .faq-item { background: var(--dark-3); border: 1px solid rgba(255,107,53,.12); border-radius: 14px; padding: 1.4rem; }
  .faq-item h3 { font-size: 1rem; font-weight: 700; margin-bottom: .6rem; }
  .faq-item p { font-size: .93rem; color: var(--text-muted); line-height: 1.7; }
  /* CTA final */
  .cta-final { background: linear-gradient(135deg, rgba(255,107,53,.15), rgba(255,107,53,.05)); border: 1px solid rgba(255,107,53,.25); border-radius: 24px; padding: 3.5rem 2rem; text-align: center; }
  .cta-final h2 { font-size: 2rem; font-weight: 800; margin-bottom: 1rem; }
  .cta-final p { color: var(--text-muted); margin-bottom: 2rem; font-size: 1.05rem; }
  .sep { height: 1px; background: rgba(255,107,53,.12); margin: 1.5rem 0; }
  @media(max-width:600px) { .hero-ctas { flex-direction: column; } .pachete-grid { grid-template-columns: 1fr; } }
</style>

<!-- HERO -->
<section class="pilon-hero">
