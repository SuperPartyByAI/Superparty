---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Animatori Petreceri Copii București | SuperParty" description="Animatori profesionisti pentru petreceri copii in Bucuresti. Personaje costumate Elsa, Spiderman, PAW Patrol. Rezerva: 0763 795 919.">
  <section style="padding:6rem 0 3rem;">
    <div class="container">
      <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:1rem;">Animatori <span style="color:var(--primary);">Petreceri Copii</span> București</h1>
      <p style="color:var(--text-muted); font-size:1.1rem; max-width:700px; margin-bottom:2rem; line-height:1.8;">Animatorii SuperParty aduc magia personajelor favorite direct la petrecerea copilului tău! Costume premium, animatori actori cu experiență, programe structurate de jocuri, teatru și surprize.</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1rem; margin-bottom:3rem;">
        {['❄️ Elsa Frozen','🕷️ Spiderman','🐕 PAW Patrol','🐞 Ladybug','🦇 Batman','🐷 Peppa Pig','💜 Rapunzel','🌺 Moana','⚡ Pikachu','🎩 Mickey Mouse'].map(p => (
          <div style="background:var(--dark-3); border:1px solid rgba(255,107,53,0.2); border-radius:12px; padding:1rem; text-align:center; font-weight:600;">{p}</div>
        ))}
      </div>
      <a href="tel:+40763795919" style="display:inline-block; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); color:white; padding:1rem 2.5rem; border-radius:50px; font-weight:700; font-size:1.1rem; text-decoration:none;">📞 Rezerva Animator</a>
    </div>
  </section>
</Layout>
