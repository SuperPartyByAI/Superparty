        { "@type": "Offer", "name": "Super 1 – 1 Personaj 2 ore", "price": "490", "priceCurrency": "RON" },
        { "@type": "Offer", "name": "Super 2 – 2 Personaje 1 oră (Luni–Vineri)", "price": "490", "priceCurrency": "RON" },
        { "@type": "Offer", "name": "Super 3 – 2 Personaje 2 ore + Confetti party", "price": "840", "priceCurrency": "RON" },
        { "@type": "Offer", "name": "Super 4 – 1 Personaj 1 oră + Tort din dulciuri", "price": "590", "priceCurrency": "RON" },
        { "@type": "Offer", "name": "Super 5 – 1 Personaj 2 ore + Vată de zahăr + Popcorn", "price": "840", "priceCurrency": "RON" },
