---

const svcSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Arcade Baloane București",
      "description": "Arcade și aranjamente baloane pentru petreceri copii în București și Ilfov. Servicii profesionale SuperParty.",
      "provider": {"@type": "LocalBusiness", "name": "SuperParty", "telephone": "+40722744377", "url": "https://www.superparty.ro"}
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Acasă", "item": "https://superparty.ro"},
        {"@type": "ListItem", "position": 2, "name": "Arcade Baloane București", "item": "https://superparty.ro/arcade-baloane"}
      ]
    }
  ]
});
import Layout from '../../layouts/Layout.astro';
---
<Layout schema={svcSchema} title="Arcadă Baloane București – Montaj la Locație, Culori Personalizate | SuperParty" description="Arcadă din baloane pentru petreceri copii și botezuri în București. Dimensiuni 1–5 m, culori la alegere, montaj rapid la locație. Transport inclus. Sună: 0722 744 377."
  canonical="https://www.superparty.ro/arcade-baloane">
  <section style="padding:6rem 0 3rem;">
    <div class="container">
      <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:1rem;">Arcade <span style="color:var(--primary);">Baloane</span> București</h1>
      <p style="color:var(--text-muted); font-size:1.1rem; max-width:700px; margin-bottom:2rem; line-height:1.8;">Arcurile din baloane sunt elementul "wow" al oricărei petreceri! Cream arcade impresionante la intrare sau in sala, personalizate in culorile si tema petrecerii tale.</p>
      <div style="background:var(--dark-2); border:1px solid rgba(255,107,53,0.2); border-radius:var(--radius); padding:2rem; margin-bottom:2rem;">
        <h2 style="color:var(--primary); margin-bottom:1rem;">Ce includem:</h2>
        <ul style="list-style:none; color:var(--text-muted);">
          {['🎈 Arcade cu dimensiuni la alegere (1-5 metri)','🎨 Culori personalizate pentru tema petrecerii','⚡ Montaj rapid la locatie','🌟 Baloane premium rezistente','✅ Transport inclus in bucuresti'].map(f => <li style="padding:0.5rem 0; border-bottom:1px solid rgba(255,255,255,0.05);">{f}</li>)}
        </ul>
      </div>
      <a href="tel:+40722744377" style="display:inline-block; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); color:white; padding:1rem 2.5rem; border-radius:50px; font-weight:700; font-size:1.1rem; text-decoration:none;">📞 Comanda Arcada</a>
    </div>
  </section>
</Layout>
