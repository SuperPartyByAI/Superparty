---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Baloane cu Heliu București – Cifre, Litere, Personaje, Folie | SuperParty" description="Baloane cu heliu latex și folie pentru petreceri copii în București. Cifre, litere, personaje favorite, stele. Livrare la locație. Rezervă rapid: 0722 744 377."
  canonical="https://www.superparty.ro/baloane-cu-heliu">
  <section style="padding:6rem 0 3rem;">
    <div class="container">
      <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:1rem;">Baloane cu <span style="color:var(--primary);">Heliu</span> București</h1>
      <p style="color:var(--text-muted); font-size:1.1rem; max-width:700px; margin-bottom:2rem; line-height:1.8;">Balonele cu heliu adauga o nota festiva oricarel petreceri! Oferim baloane latex si folie in forme diverse, personaje, cifre si litere — perfecte pentru poze si atmosfera!</p>
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1rem; margin-bottom:3rem;">
        {['🎈 Baloane Latex Rotunde','⭐ Baloane Folie Stele','🔢 Baloane Cifre','🔤 Baloane Litere','👑 Baloane Personaje','🦋 Baloane Forme Diverse'].map(b => (
          <div style="background:var(--dark-3); border:1px solid rgba(255,107,53,0.2); border-radius:12px; padding:1rem; text-align:center; font-weight:600;">{b}</div>
        ))}
      </div>
      <a href="tel:+40722744377" style="display:inline-block; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); color:white; padding:1rem 2.5rem; border-radius:50px; font-weight:700; font-size:1.1rem; text-decoration:none;">📞 Comanda Baloane</a>
      <p style="color:var(--text-muted); font-size:0.95rem; margin-top:1.5rem;">Adaugă și <a href="/animatori-petreceri-copii/" style="color:var(--primary); font-weight:600;">animatori petreceri copii</a> — pachete complete cu personaje de la 490 lei.</p>
    </div>
  </section>
</Layout>
