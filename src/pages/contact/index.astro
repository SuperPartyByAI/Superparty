---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Contact SuperParty București | 0722 744 377" description="Contacteaza SuperParty pentru petreceri copii in Bucuresti. Suntem disponibili 7/7. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/contact">
  <section style="padding:6rem 0 3rem;">
    <div class="container" style="max-width:700px;">
      <h1 style="font-size:2.5rem; font-weight:800; margin-bottom:1rem;">Contactează <span style="color:var(--primary);">SuperParty</span></h1>
      <p style="color:var(--text-muted); font-size:1.1rem; margin-bottom:3rem;">Suntem disponibili 7 zile din 7 pentru a organiza petrecerea perfecta pentru copilul tau!</p>
      <div style="display:grid; gap:1.5rem;">
        {[
          ['📞', 'Telefon', '0722 744 377', 'tel:+40722744377'],
          ['💬', 'WhatsApp', 'Scrie-ne pe WhatsApp', 'https://wa.me/40722744377'],
          ['📅', 'Program', 'Luni-Duminica: 08:00-22:00', null],
          ['📍', 'Zona', 'Bucuresti si Ilfov', null],
        ].map(([icon, label, value, link]) => (
          <div style="background:var(--dark-2); border:1px solid rgba(255,107,53,0.2); border-radius:var(--radius); padding:1.5rem; display:flex; gap:1rem; align-items:center;">
            <span style="font-size:2rem;">{icon}</span>
            <div>
              <p style="font-weight:700; margin-bottom:0.25rem;">{label}</p>
              {link ? <a href={link} style="color:var(--primary); font-weight:600; text-decoration:none;">{value}</a> : <p style="color:var(--text-muted);">{value}</p>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
