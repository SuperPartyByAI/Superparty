---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('ghid');
posts.sort((a, b) => (b.data.pubDate?.valueOf() || 0) - (a.data.pubDate?.valueOf() || 0));
---

<Layout title="Ghidul Părinților: Sfaturi și Idei pentru Petreceri Copii | SuperParty" description="Sfaturi de top, idei de jocuri, bugete și recomandări pentru a organiza cea mai reușită petrecere pentru copilul tău în București și Ilfov.">
  <main class="ghid-index">
    <header class="ghid-header" style="padding:6rem 1rem 4rem;background:var(--dark-1,#0f0f1a);text-align:center;border-bottom:1px solid rgba(255,255,255,0.05)">
      <div class="container">
        <h1 style="font-size:3rem;font-weight:900;color:#fff;margin-bottom:1rem;line-height:1.2">Ghidul Părinților <span style="color:#F97316">SuperParty</span></h1>
        <p style="color:var(--text-muted,#94a3b8);font-size:1.15rem;max-width:700px;margin:0 auto;line-height:1.6">
          Zeci de idei testate, sfaturi de organizare și soluții anti-stres pentru ziua copilului tău. De la bugetare până la cele mai bune jocuri de petrecere.
        </p>
      </div>
    </header>

    <section class="ghid-grid" style="padding:5rem 0;background:var(--dark-2,#1a1a2e)">
      <div class="container">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:2.5rem">
          {posts.map((post) => (
            <article class="post-card" style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.05);border-radius:12px;overflow:hidden;transition:transform 0.3s ease">
              <a href={`/ghid/${post.slug}`} style="text-decoration:none;color:inherit;display:block">
                {post.data.coverImage && (
                  <div class="card-img" style="aspect-ratio:16/9;background:#2a2a3e;overflow:hidden">
                    <img src={post.data.coverImage} alt={post.data.title} style="width:100%;height:100%;object-fit:cover;object-position:center" loading="lazy" />
                  </div>
                )}
                <div class="card-content" style="padding:1.5rem">
                  <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;font-size:0.85rem">
                    <span style="background:rgba(249,115,22,0.1);color:#F97316;padding:0.2rem 0.8rem;border-radius:20px;font-weight:600">{post.data.category || 'Organizare'}</span>
                    <span style="color:#64748b">{post.data.readTime || '5 min citire'}</span>
                  </div>
                  <h2 style="font-size:1.25rem;color:#fff;font-weight:700;line-height:1.4;margin-bottom:0.8rem">{post.data.title}</h2>
                  <p style="color:#94a3b8;font-size:0.95rem;line-height:1.6;margin-bottom:1.5rem">{post.data.description}</p>
                  <span style="color:#22d3ee;font-weight:600;font-size:0.95rem">Citește mai mult →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SEO LINK JUICE BOTTOM -->
    <section class="cta-juice" style="padding:4rem 0;background:#F97316;text-align:center">
      <div class="container">
        <h2 style="font-size:2rem;color:#fff;font-weight:900;margin-bottom:1rem">Nu ai timp să organizezi singur?</h2>
        <p style="color:rgba(255,255,255,0.9);font-size:1.1rem;margin-bottom:2rem;max-width:600px;margin-left:auto;margin-right:auto">Lăsăm noi grijile la ușă! Oferim pachete complete de <strong>animatori petreceri copii</strong>, vată de zahăr, mașină de popcorn și decorațiuni.</p>
        <a href="/" style="display:inline-block;background:#fff;color:#F97316;font-weight:800;font-size:1.1rem;padding:1rem 2rem;border-radius:8px;text-decoration:none;box-shadow:0 10px 25px rgba(0,0,0,0.1)">Vezi Pachetele Noastre</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .post-card:hover { transform: translateY(-5px); box-shadow: 0 15px 30px rgba(0,0,0,0.2); border-color: rgba(34,211,238,0.3) !important; }
</style>
