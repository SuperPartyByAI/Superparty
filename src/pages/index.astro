---
import Layout from '../layouts/Layout.astro';
import Testimonials from '../components/Testimonials.astro';
const currentYear = new Date().getFullYear();
const WA_TEXT = encodeURIComponent('Bună! Vreau să rezerv animatori pentru petrecerea copilului meu.\nData: \nLocalitate/Sector: \nVârsta copilului: \nNr. copii: \nPachet dorit (opțional): ');
const WA_URL = `https://wa.me/40722744377?text=${WA_TEXT}`;
---
<Layout title="SuperParty — Animatori Petreceri Copii București | Nr. 1" description="Animatori profesionisti pentru petreceri copii in Bucuresti si Ilfov. Personaje costumate, baloane, decoratiuni. Rezerva acum: 0722 744 377.">

  <!-- HERO -->
  <section style="position:relative; overflow:hidden; min-height:90vh; display:flex; align-items:center;">
    <div style="position:absolute; inset:0; background: radial-gradient(ellipse at 20% 50%, rgba(255,107,53,0.25) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(255,215,0,0.2) 0%, transparent 60%), var(--dark); z-index:0;"></div>
    <div style="position:absolute; inset:0; z-index:0;" id="stars-bg"></div>

    <div class="container" style="position:relative; z-index:1; padding-top:3rem; padding-bottom:3rem;">
      <div style="max-width:680px;">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(255,107,53,0.15); border:1px solid rgba(255,107,53,0.35); border-radius:50px; padding:0.4rem 1rem; font-size:0.85rem; color:#ff8c5a; margin-bottom:1.5rem; font-weight:600;">
          🎉 8.000+ Petreceri Organizate în București și Ilfov
        </div>

        <h1 style="font-size:clamp(1.8rem, 8vw, 3.6rem); font-weight:800; line-height:1.15; margin-bottom:1.5rem; word-break: break-word; -webkit-hyphens: auto; hyphens: auto;">
          <span style="background: linear-gradient(135deg, #fff 0%, #ffe8d6 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Animatori</span><br/>
          <span style="background: linear-gradient(135deg, var(--primary), var(--accent)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Petreceri Copii</span><br/>
          <span style="background: linear-gradient(135deg, #fff 0%, #ffe8d6 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">București</span>
        </h1>

        <p style="font-size:1.15rem; color:var(--text-muted); margin-bottom:2rem; max-width:520px; line-height:1.7;">
          Aducem magia personajelor favorite direct la petrecerea copilului! Costume premium, animatori actori, baloane, decoratiuni.
        </p>

        <div style="display:flex; gap:1rem; flex-wrap:wrap;">
          <a href="tel:+40722744377" style="display:inline-flex; align-items:center; gap:0.5rem; background:linear-gradient(135deg, var(--primary), var(--primary-dark)); color:white; padding:0.9rem 2rem; border-radius:50px; font-weight:700; font-size:1.05rem; box-shadow:0 8px 30px rgba(255,107,53,0.4); text-decoration:none; transition:transform 0.2s;">
            📞 Rezerva Acum — 0722 744 377
          </a>
          <a href="#servicii" style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); color:white; padding:0.9rem 2rem; border-radius:50px; font-weight:600; text-decoration:none;">
            Vezi Servicii ↓
          </a>
        </div>

        <div style="display:flex; gap:2rem; margin-top:2.5rem; flex-wrap:wrap;">
          {[['🎉', '8.000+', 'Petreceri'], ['👑', '30+', 'Personaje'], ['⭐', '1.498+', 'Recenzii reale'], ['📅', '7/7', 'Disponibil']].map(([icon, num, label]) => (
            <div style="text-align:center;">
              <p style="font-size:1.4rem;">{icon}</p>
              <p style="font-size:1.1rem; font-weight:800; color:var(--accent);">{num}</p>
              <p style="font-size:0.8rem; color:var(--text-muted);">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Floating emojis -->
    <div style="position:absolute; right:5%; top:15%; font-size:5rem; z-index:0; animation:float 4s ease-in-out infinite; opacity:0.8; pointer-events:none;">🎉</div>
    <div style="position:absolute; right:8%; bottom:30%; font-size:4rem; z-index:0; animation:float 5s ease-in-out infinite 1s; opacity:0.6; pointer-events:none;">🎈</div>
    <div style="position:absolute; right:2%; bottom:10%; font-size:3.5rem; z-index:0; animation:float 3.5s ease-in-out infinite 0.5s; opacity:0.6; pointer-events:none;">🎊</div>
  </section>

  <!-- SERVICII -->
  <section id="servicii" style="padding:5rem 0; background:var(--dark-2);">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <h2 style="font-size:2rem; font-weight:800; margin-bottom:0.75rem;">Serviciile <span style="color:var(--primary);">Noastre</span></h2>
        <p style="color:var(--text-muted);">Tot ce ai nevoie pentru o petrecere perfectă</p>
      </div>
      <div class="services-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:1.5rem;">
        {[
          ['🎭', 'Animatori Petreceri Copii', 'animatori profesionisti costumati in personajele favorite', '/animatori-petreceri-copii/'],
          ['🎈', 'Decoratiuni Baloane', 'arcade, aranjamente si decoruri din baloane premium', '/decoratiuni-baloane/'],
          ['🎀', 'Arcade Baloane', 'arcuri spectaculoase din baloane pentru intrare', '/arcade-baloane/'],
          ['🎁', 'Baloane cu Heliu', 'baloane cu heliu in forme si culori diverse', '/baloane-cu-heliu/'],
          ['👼', 'Ursitoare Botez', 'ursitoare profesioniste pentru ceremonia botezului', '/ursitoare-botez/'],
          ['🎅', 'Moș Crăciun de Închiriat', 'mos craciun autentic pentru surprize de neuitat', '/mos-craciun-de-inchiriat/'],
          ['🪅', 'Piniata', 'piniate personalizate pentru distractie garantata', '/piniata/'],
          ['🍭', 'Vată de Zahăr și Popcorn', 'masini profesionale de vata si popcorn pentru petreceri', '/vata-de-zahar-si-popcorn/'],
        ].map(([icon, title, desc, link]) => (
          <a href={link} class="service-card">
            <p style="font-size:2.5rem; margin-bottom:0.75rem;">{icon}</p>
            <h3 style="font-size:1rem; font-weight:700; color:var(--text); margin-bottom:0.4rem;">{title}</h3>
            <p style="font-size:0.85rem; color:var(--text-muted);">{desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PACHETE & PRETURI -->
  <section id="pachete" style="padding:5rem 0;">
    <div class="container">
      <div style="text-align:center; margin-bottom:3rem;">
        <h2 style="font-size:2rem; font-weight:800; margin-bottom:0.75rem;">Pachete și <span style="color:var(--accent);">Prețuri</span> {currentYear}</h2>
        <p style="color:var(--text-muted);">Preturi transparente, fara costuri ascunse</p>
      </div>
      <div class="packages-grid">
        {[
          { name: 'Super 1', price: '490 lei', duration: '1 Personaj · 2 ore', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față'], highlight: false },
          { name: 'Super 2', price: '490 lei', duration: '2 Personaje · 1 oră (Luni-Vineri)', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față'], highlight: false },
          { name: 'Super 3', price: '840 lei', duration: '2 Personaje · 2 ore + Confetti', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față', 'Confetti party'], highlight: true },
          { name: 'Super 4', price: '590 lei', duration: '1 Personaj · 1 oră + Tort dulciuri', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față', 'Tort din dulciuri'], highlight: false },
          { name: 'Super 5', price: '840 lei', duration: '1 Pers. · 2 ore + 1h Vată + 1h Popcorn', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față', 'Mașină vată de zahăr și popcorn'], highlight: false },
          { name: 'Super 6', price: '540 lei', duration: '1 Animator · 2 ore + Banner + Confetti', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față', 'Banner personalizat + Tun confetti'], highlight: false },
          { name: 'Super 7', price: '1290 lei', duration: '1 Animator · 3 ore + 4 Ursitoare', features: ['Personaj la alegere (+170 lei extra)', 'Diplome magnetice', 'Jocuri și concursuri', 'Baloane modelate', 'Boxă portabilă', 'Dansuri și coregrafii', 'Tatuaje temporare', 'Transport gratuit București', 'Pictură pe față', 'Spectacol 4 ursitoare botez'], highlight: false },
        ].map((pkg) => (
          <div class={`pkg-card ${pkg.highlight ? 'pkg-featured' : ''}`}>
            {pkg.highlight && <div class="pkg-badge">CEL MAI ALES</div>}
            <h3 class="pkg-name">{pkg.name}</h3>
            <p class="pkg-price">{pkg.price}</p>
            <p class="pkg-duration">{pkg.duration}</p>
            <ul class="pkg-features">
              {pkg.features.map(f => <li>✅ {f}</li>)}
            </ul>
            <a href="tel:+40722744377" class={`pkg-cta ${pkg.highlight ? 'pkg-cta-primary' : 'pkg-cta-secondary'}`}>
              Rezervă {pkg.name}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALE -->
  <Testimonials count={12} title="Ce Spun Părinții" showLink={true} />

  <!-- CTA -->
  <section style="padding:5rem 0; background:linear-gradient(135deg, var(--dark-3), var(--dark-2)); text-align:center;">
    <div class="container">
      <p style="font-size:3rem; margin-bottom:1.5rem;">🎊</p>
      <h2 style="font-size:2.2rem; font-weight:800; margin-bottom:1rem;">Rezervă Petrecerea Perfectă<br/><span style="color:var(--primary);">Chiar Acum!</span></h2>
      <p style="color:var(--text-muted); font-size:1.1rem; max-width:500px; margin:0 auto 2rem;">Weekendurile se ocupă rapid! Contactează-ne acum pentru disponibilitate.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="tel:+40722744377" style="background:linear-gradient(135deg, var(--primary), var(--primary-dark)); color:white; padding:1rem 2.5rem; border-radius:50px; font-size:1.1rem; font-weight:700; text-decoration:none; box-shadow:0 8px 30px rgba(255,107,53,0.5);" class="cta">📞 Sună Acum</a>
        <a href={WA_URL} target="_blank" rel="noopener noreferrer" style="background:#25d366; color:white; padding:1rem 2.5rem; border-radius:50px; font-size:1.1rem; font-weight:700; text-decoration:none;" class="cta">💬 WhatsApp</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .service-card {
    display: block; background: var(--dark-3); border: 1px solid rgba(255,107,53,0.15);
    border-radius: var(--radius); padding: 1.5rem; text-decoration: none; transition: all 0.25s;
  }
  .service-card:hover { transform: translateY(-5px); border-color: rgba(255,107,53,0.5); box-shadow: 0 8px 25px rgba(255,107,53,0.2); }
  .packages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 0;
  }
  .pkg-card { background: var(--dark-2); border: 2px solid rgba(255,255,255,0.08); border-radius: var(--radius); padding: 2rem; position: relative; transition: border-color 0.2s; }
  .pkg-card:hover { border-color: rgba(255,107,53,0.3); }
  .pkg-featured { border-color: var(--primary) !important; box-shadow: 0 12px 40px rgba(255,107,53,0.3); transform: scale(1.02); }
  .pkg-badge { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); background: var(--primary); color: white; padding: 0.25rem 1rem; border-radius: 50px; font-size: 0.8rem; font-weight: 700; white-space: nowrap; }
  .pkg-name { font-size: 1.3rem; font-weight: 800; margin-bottom: 0.5rem; }
  .pkg-price { font-size: 2.5rem; font-weight: 800; color: var(--accent); margin-bottom: 0.25rem; }
  .pkg-duration { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; }
  .pkg-features { list-style: none; margin-bottom: 2rem; }
  .pkg-features li { padding: 0.4rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.88rem; }
  .pkg-cta { display: block; text-align: center; padding: 0.85rem; border-radius: 50px; font-weight: 700; color: white; text-decoration: none; transition: opacity 0.2s; }
  .pkg-cta:hover { opacity: 0.9; }
  .pkg-cta-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); }
  .pkg-cta-secondary { background: rgba(255,255,255,0.1); }
  @media (max-width: 640px) {
    .packages-grid { grid-template-columns: 1fr; }
    .pkg-featured { transform: none; }
  }
</style>

<script>
  const bg = document.getElementById('stars-bg');
  if (bg) {
    for (let i = 0; i < 80; i++) {
      const star = document.createElement('div');
      const size = Math.random() * 3 + 1;
      star.style.cssText = `position:absolute; width:${size}px; height:${size}px; background:rgba(255,255,255,${Math.random() * 0.5 + 0.2}); border-radius:50%; left:${Math.random()*100}%; top:${Math.random()*100}%; animation:glow ${2 + Math.random()*3}s ease-in-out infinite ${Math.random()*3}s;`;
      bg.appendChild(star);
    }
  }
</script>
