---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Superparty.ro | Festivalul Tău la Pachet">
  <div class="bg-gradient-to-br from-pink-500 via-pink-600 to-violet-700 py-32 text-center text-white relative overflow-hidden">
    <div class="relative z-10 max-w-4xl mx-auto px-4">
      <span class="inline-block py-1.5 px-4 rounded-full bg-white/20 backdrop-blur-md font-bold text-xs md:text-sm tracking-widest uppercase mb-4 md:mb-6 shadow-sm border border-white/30 text-center">Pachetul All-Inclusive</span>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold mb-4 md:mb-6 tracking-tight drop-shadow-md leading-tight">Festivalul tău,<br class="md:hidden"/> fără efort pentru tine</h1>
      <p class="text-lg sm:text-xl md:text-2xl font-light mb-8 md:mb-12 opacity-90 max-w-2xl mx-auto leading-relaxed">Tu zâmbești și faci poze, noi aducem magia cu Animatori, Baloane și Ursitoare direct la petrecere.</p>
      
      <div class="flex flex-col sm:flex-row gap-3 w-full max-w-sm sm:max-w-none mx-auto justify-center">
        <a href="/pachete" class="bg-white text-pink-600 font-bold px-6 py-3 md:px-8 md:py-4 rounded-full shadow-xl hover:scale-105 transition-transform flex items-center justify-center text-center">✅ Vezi Oferta Zero Stres</a>
        <a href="tel:0700000000" class="bg-transparent border-2 border-white text-white font-bold px-6 py-3 md:px-8 md:py-4 rounded-full hover:bg-white/10 transition-colors flex items-center justify-center text-center">📞 0700 000 000</a>
      </div>
    </div>
  </div>
</BaseLayout>
