---
import Layout from '../layouts/Layout.astro';
import Testimonials from '../components/Testimonials.astro';
import PhotoSlider from '../components/PhotoSlider.astro';
import { heroImages, productImages } from '../data/gallery_images';

const currentYear = new Date().getFullYear();
const WA_TEXT = encodeURIComponent('Bună! Vreau să rezerv animatori pentru petrecerea copilului meu.\nData: \nLocalitate/Sector: \nVârsta copilului: \nNr. copii: \nPachet dorit (opțional): ');
const WA_URL = `https://wa.me/40722744377?text=${WA_TEXT}`;

const homeSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "SuperParty",
      "description": "Animatori profesioniști pentru petreceri copii în București și Ilfov. Pachete de la 490 RON, garantie contractuală.",
      "url": "https://www.superparty.ro",
      "telephone": "+40722744377",
      "priceRange": "490-1290 RON",
      "address": {"@type": "PostalAddress", "addressLocality": "București", "addressCountry": "RO"},
      "areaServed": ["București", "Ilfov"],
      "image": "https://www.superparty.ro/images/hero-party.jpg",
      "aggregateRating": {"@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "1498"},
      "openingHours": "Mo-Su 08:00-22:00"
    },
    {
      "@type": "WebSite",
      "name": "SuperParty",
      "url": "https://www.superparty.ro",
      "potentialAction": {"@type": "SearchAction", "target": "https://www.superparty.ro/?s={search_term_string}", "query-input": "required name=search_term_string"}
    }
  ]
});

const packages = [
  { name: 'Super 1', price: '490 lei', duration: '1 Personaj · 2 ore', key: 'super1',
    features: ['Jocuri & concursuri interactive', 'Baloane modelate', 'Pictură pe față', 'Dansuri & coregrafii', 'Tatuaje temporare', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
  { name: 'Super 2', price: '490 lei', duration: '2 Personaje · 1 oră (L–V)', key: 'super2',
    features: ['Jocuri & concursuri interactive', 'Baloane modelate', 'Pictură pe față', 'Dansuri & coregrafii', 'Tatuaje temporare', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
  { name: 'Super 3 ⭐', price: '840 lei', duration: '2 Personaje · 2 ore + Confetti', key: 'super3',
    features: ['Jocuri & concursuri interactive', 'Confetti party', 'Baloane modelate', 'Pictură pe față', 'Dansuri & coregrafii', 'Tatuaje temporare', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: true },
  { name: 'Super 4', price: '590 lei', duration: '1 Personaj · 1 oră + Tort dulciuri', key: 'super4',
    features: ['Tort din dulciuri (22–24 copii)', 'Jocuri & concursuri', 'Baloane modelate', 'Pictură pe față', 'Dansuri', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
  { name: 'Super 5', price: '840 lei', duration: '1 Pers. · 2 ore + 1h Vată + 1h Popcorn', key: 'super5',
    features: ['Mașină vată de zahăr + popcorn', 'Jocuri & concursuri', 'Baloane modelate', 'Pictură pe față', 'Dansuri', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
  { name: 'Super 6', price: '540 lei', duration: '1 Animator · 2 ore + Banner + Confetti', key: 'super6',
    features: ['Banner personalizat + Tun confetti', 'Jocuri & concursuri', 'Baloane modelate', 'Pictură pe față', 'Dansuri', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
  { name: 'Super 7 🎭', price: '1290 lei', duration: '1 Animator · 3 ore + 4 Ursitoare', key: 'super7',
    features: ['Spectacol 4 ursitoare botez', 'Jocuri & concursuri', 'Baloane modelate', 'Pictură pe față', 'Dansuri', 'Diplome magnetice', 'Boxă portabilă', 'Transport gratuit București'], highlight: false },
];

const benefits = [
  { icon: '🎉', title: 'Veselie adaptată', desc: 'Animatorii noștri conduc activități interactive adaptate vârstei copiilor. Ne străduim să oferim o experiență plăcută — pentru nevoi speciale, contactați-ne înainte de eveniment.' },
  { icon: '👫', title: 'Socializare ușoară', desc: 'Activitățile noastre sunt gândite să faciliteze cooperarea între copii și să transforme repede grupul în echipă.' },
  { icon: '🎭', title: 'Peste 150 de personaje', desc: 'De la Spiderman la Elsa și zeci de alte personaje — avem o colecție extinsă de costume autentice. Spune-ne personajul preferat și verificăm disponibilitatea.' },
  { icon: '💛', title: 'Grijă și adaptare', desc: 'Animatorii noștri au experiență cu diferite grupe de vârstă și adaptează activitățile conform nevoilor. Pentru grupuri speciale, contactați-ne în prealabil.' },
];
---

<Layout
  title="SuperParty — Animatori Petreceri Copii București & Ilfov"
  description="Animatori profesioniști pentru petreceri copii în București și Ilfov. 8.000+ petreceri. Personaje costumate, jocuri, baloane, confetti. Rezervă: 0722 744 377."
  canonical="https://www.superparty.ro/"
>

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<section class="hero-lw">
  <div class="hero-img-wrap">
    <img
      class="hero-img"
      src={heroImages[0].src}
      alt={heroImages[0].alt}
      width="1400"
      height="800"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-badge">🎉 8.000+ Petreceri în București &amp; Ilfov</div>

    <h1 class="hero-h1">
      Animatori<br/>
      <span class="hero-accent">Petreceri Copii</span><br/>
      București
    </h1>

    <p class="hero-sub">
      Personaje costumate, jocuri interactive, confetti party, pictură pe față &amp; baloane.<br/>
      Aducem magia direct la petrecerea copilului!
    </p>

    <div class="hero-ctas">
      <a href="tel:+40722744377" class="btn-primary" id="hero-call-cta">
        📞 Sună Acum — 0722 744 377
      </a>
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-wa" id="hero-wa-cta">
        💬 WhatsApp
      </a>
    </div>

    <!-- SEO Internal Link -->
    <div style="margin-top: 1.5rem; text-align: center;">
      <a href="/animatori-petreceri-copii/" style="color: white; text-decoration: underline; font-weight: 500; font-size: 1.1rem; opacity: 0.9;">
        Animatori petreceri copii — Pachete de la 490 lei
      </a>
    </div>

    <div class="hero-stats">
      {([
        ['🎉', '8.000+', 'Petreceri'],
        ['👑', '30+', 'Personaje'],
        ['⭐', '1.498+', 'Recenzii reale'],
        ['📅', '7/7', 'Disponibil'],
      ] as const).map(([icon, num, label]) => (
        <div class="hero-stat">
          <span class="stat-icon">{icon}</span>
          <span class="stat-num">{num}</span>
          <span class="stat-lbl">{label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── SLIDER "Cum arată o petrecere" ────────────────────────────────── -->
<PhotoSlider title="Cum arată o petrecere SuperParty" />

<!-- ── BENEFICII (4 carduri) ─────────────────────────────────────────── -->
<section class="benefits-section">
  <div class="container">
    <div class="section-hdr">
      <h2 class="section-title">De ce copiii <span class="accent-text">adoră</span> SuperParty</h2>
      <p class="section-sub">Nu e un simplu animator — e o experiență completă</p>
    </div>
    <div class="benefits-grid">
      {benefits.map(b => (
        <div class="benefit-card">
          <div class="benefit-icon">{b.icon}</div>
          <h3 class="benefit-title">{b.title}</h3>
          <p class="benefit-desc">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ── SERVICII (grid compact) ───────────────────────────────────────── -->
<section id="servicii" class="services-section">
  <div class="container">
    <div class="section-hdr">
      <h2 class="section-title">Servicii <span class="accent-text">SuperParty</span></h2>
      <p class="section-sub">Tot ce ai nevoie pentru o petrecere perfectă</p>
    </div>
    <div class="services-grid">
      {([
        ['🎭', 'Animatori Petreceri Copii', 'Personaje + jocuri + baloane + pictură + dansuri', '/animatori-petreceri-copii/'],
        ['🎈', 'Decorațiuni Baloane', 'Arcade, aranjamente și decoruri premium', '/decoratiuni-baloane/'],
        ['🎀', 'Arcade Baloane', 'Arcuri spectaculoase la intrare', '/arcade-baloane/'],
        ['🎁', 'Baloane cu Heliu', 'Baloane cu heliu diverse forme', '/baloane-cu-heliu/'],
        ['👼', 'Ursitoare Botez', 'Spectacol ursitoare 4 personaje', '/ursitoare-botez/'],
        ['🎅', 'Moș Crăciun', 'Moș Crăciun autentic acasă', '/mos-craciun-de-inchiriat/'],
        ['🪅', 'Piniată', 'Piniate personalizate de distracție', '/piniata/'],
        ['🍭', 'Vată & Popcorn', 'Mașini profesionale vată + popcorn', '/vata-de-zahar-si-popcorn/'],
      ] as const).map(([icon, title, desc, link]) => (
        <a href={link} class="svc-card" id={`svc-${title.toLowerCase().replace(/[^a-z]/g,'-')}`}>
          <span class="svc-icon">{icon}</span>
          <h3 class="svc-title">{title}</h3>
          <p class="svc-desc">{desc}</p>
          <span class="svc-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── PACHETE & PREȚURI ──────────────────────────────────────────────── -->
<section id="pachete" class="packages-section">
  <div class="container">
    <div class="section-hdr">
      <h2 class="section-title">Pachete &amp; <span class="accent-text">Prețuri</span> {currentYear}</h2>
      <p class="section-sub">Prețuri transparente, fără costuri ascunse</p>
    </div>
    <div class="packages-grid">
      {packages.map(pkg => (
        <div class={`pkg-card${pkg.highlight ? ' pkg-featured' : ''}`}>
          {pkg.highlight && <div class="pkg-badge">CEL MAI ALES</div>}
          <img
            class="pkg-img"
            src={productImages[pkg.key]}
            alt={`Pachet ${pkg.name}`}
            width="400"
            height="200"
            loading="lazy"
            decoding="async"
          />
          <div class="pkg-body">
            <h3 class="pkg-name">{pkg.name}</h3>
            <p class="pkg-price">{pkg.price}</p>
            <p class="pkg-duration">{pkg.duration}</p>
            <ul class="pkg-features">
              {pkg.features.map(f => <li>✓ {f}</li>)}
            </ul>
            <a href="tel:+40722744377" class={`pkg-cta${pkg.highlight ? ' pkg-cta-primary' : ' pkg-cta-secondary'}`} id={`pkg-cta-${pkg.key}`}>
              Rezervă {pkg.name}
            </a>
          </div>
        </div>
      ))}
    </div>
    <p class="pkg-note">Extra personaj / oră: +170 lei · Acoperim București & Ilfov · Disponibil 7/7</p>
  </div>
</section>

<!-- ── TESTIMONIALE ────────────────────────────────────────────────────── -->
<Testimonials count={9} title="Ce spun părinții" showLink={true} />

<!-- ── CTA FINAL ──────────────────────────────────────────────────────── -->
<section class="cta-section">
  <div class="container cta-inner">
    <div class="cta-text">
      <h2 class="cta-title">Rezervă petrecerea perfectă<br/><span class="cta-accent">chiar acum!</span></h2>
      <p class="cta-sub">Weekendurile se ocupă rapid! Contactează-ne pentru disponibilitate.</p>
    </div>
    <div class="cta-actions">
      <a href="tel:+40722744377" class="btn-primary btn-lg" id="footer-call-cta">📞 Sună: 0722 744 377</a>
      <a href={WA_URL} target="_blank" rel="noopener noreferrer" class="btn-wa btn-lg" id="footer-wa-cta">💬 WhatsApp</a>
    </div>
  </div>
</section>


<!-- EXPAND-1500W-MARKER-București-&-Ilfov -->
<section class="extra-content-section" style="padding:3rem 0;background:linear-gradient(180deg,rgba(255,255,255,0.03),transparent)">
  <div class="container">
    <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-primary,#fff);margin-bottom:1.2rem">Cum organizezi petrecerea perfectă pentru copilul tău în București & Ilfov?</h2>
    <p style="color:var(--text-muted);line-height:1.9;margin-bottom:1rem">Organizarea unei petreceri pentru copii în zona metropolitană București-Ilfov, deplasare 30 RON implică mai mulți pași esențiali. SuperParty simplifică totul: tu alegi data, personajul preferat al copilului și numărul de participanți — noi ne ocupăm de restul. Procesul de rezervare durează sub 10 minute: trimiți un mesaj WhatsApp la <strong>0722 744 377</strong> sau completezi formularul de pe site, primești o confirmare în 30 de minute și un contract de garanție care îți protejează rezervarea.</p>
    <p style="color:var(--text-muted);line-height:1.9;margin-bottom:1rem">SuperParty vine la București & Ilfov echipat cu tot ce este nevoie: costum premium (nu de carnaval ieftin — costume profesionale cu detalii fidele personajului), materiale pentru <strong>face painting</strong> (culori certificate non-toxice, testate dermatologic pentru copii), materiale pentru modelarea baloanelor (minimum 60 de baloane per eveniment), mașina de baloane de săpun cu debit ridicat și echipamentul de sonorizare portabil pentru muzica tematică a personajului ales. Animatorul sosește cu 15 minute înainte de eveniment pentru setup.</p>
    <p style="color:var(--text-muted);line-height:1.9;margin-bottom:1rem">Durata standard a unui eveniment SuperParty este de <strong>2 ore</strong> (pachet Classic) sau <strong>3 ore</strong> (pachet Premium și VIP). În 2 ore, un animator SuperParty reușește să facă: intrarea spectaculoasă în personaj (5 min), activitate de ice-breaking cu toți copiii (10 min), 3-4 jocuri interactive adaptate vârstei (40 min), sesiune de face painting (30 min), modelare baloane (20 min), mașina de baloane de săpun (10 min) și momentul special cu tortul + cântecul (5 min). Este un program dens, bine orchestrat prin <strong>10 ani de experiență</strong> cu peste 10.000 de evenimente.</p>
    <p style="color:var(--text-muted);line-height:1.9">Un detaliu important: SuperParty garantează personajul ales prin contract. Niciodată nu vine alt personaj în locul celui rezervat, niciodată un costum de calitate slabă. Dacă din motive independente de voința noastră nu putem respecta contractul, îți returnăm integral avansul plătit și acoperim cheltuielile dovedite ale petrecerii. Zero riscuri pentru tine.</p>
  </div>
</section>

<section class="extra-content-section" style="padding:3rem 0;background:var(--dark-2,#1a1a2e)">
  <div class="container">
    <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-primary,#fff);margin-bottom:1.2rem">Cele mai populare personaje la petrecerile din București & Ilfov în 2025</h2>
    <p style="color:var(--text-muted);line-height:1.9;margin-bottom:1rem">Pe baza datelor din sutele de petreceri organizate în zona București & Ilfov și împrejurimi, iată top 10 personaje cele mai solicitate de copiii din această zonă în 2025:</p>
    <ol style="color:var(--text-muted);line-height:2;padding-left:1.5rem;margin-bottom:1rem">
      <li><strong>Elsa și Anna (Frozen)</strong> — preferata fetițelor 3-7 ani, cerere crescând cu 40% față de 2024</li>
      <li><strong>Spiderman</strong> — liderul absolut la băieți 4-9 ani, costum cu efecte luminoase LED</li>
      <li><strong>Paw Patrol (Marshall sau Chase)</strong> — favoritul copiilor 2-5 ani</li>
      <li><strong>Mickey și Minnie Mouse</strong> — clasic neobosite, perfect pentru petreceri mixte</li>
      <li><strong>Stitch</strong> — nou în top, explozie de popularitate după filmul 2025</li>
      <li><strong>Batman / Superman</strong> — super-eroii DC, cerere constantă la băieți 5-10 ani</li>
      <li><strong>Moana</strong> — foarte populară la fetițe, costum detaliat cu accesorii</li>
      <li><strong>Pokemon (Pikachu)</strong> — nostalgie pentru părinți, adorat de copiii 6-10 ani</li>
      <li><strong>Sonic</strong> — a urcat spectaculos în clasament, cerere triplată în 2025</li>
      <li><strong>Bluey</strong> — personajul-revelație, cerere explozivă de la copiii 2-5 ani</li>
    </ol>
    <p style="color:var(--text-muted);line-height:1.9">SuperParty are <strong>50+ de personaje disponibile</strong> — dacă nu găsești personajul preferat al copilului în lista de pe site, contactează-ne: avem adesea personaje noi care nu sunt încă publicate. Rezervarea se poate face cu maxim 6 luni în avans (pentru datele de weekend din sezon — mai, iunie, septembrie, octombrie se rezervă rapid).</p>
  </div>
</section>

<section class="extra-content-section" style="padding:3rem 0">
  <div class="container">
    <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-primary,#fff);margin-bottom:1.2rem">Prețuri transparente pentru animatori în București & Ilfov — fără surprize</h2>
    <p style="color:var(--text-muted);line-height:1.9;margin-bottom:1rem">SuperParty are o politică de <strong>preț transparent și fix</strong> — prețul din ofertă este prețul final, fără costuri ascunse adăugate la final de eveniment. Iată exact ce include fiecare pachet pentru petrecerile din zona București & Ilfov:</p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.2rem;margin-bottom:1.5rem">
      <div style="background:rgba(255,255,255,0.05);border-radius:12px;padding:1.5rem;border:1px solid rgba(255,255,255,0.1)">
        <h3 style="font-size:1.1rem;font-weight:800;color:var(--primary,#ff6b35);margin-bottom:.8rem">Pachet Classic — 490 RON</h3>
        <ul style="color:var(--text-muted);line-height:2;list-style:none;padding:0;margin:0">
          <li>✅ 2 ore animator profesionist</li>
          <li>✅ Costum personaj ales</li>
          <li>✅ Face painting</li>
          <li>✅ Jocuri interactive</li>
          <li>✅ Modelare baloane (min. 60 buc.)</li>
          <li>✅ Mașina baloane de săpun</li>
          <li>✅ Contract garanție</li>
        </ul>
      </div>
      <div style="background:rgba(255,180,0,0.08);border-radius:12px;padding:1.5rem;border:1px solid rgba(255,180,0,0.3)">
        <h3 style="font-size:1.1rem;font-weight:800;color:#f0b429;margin-bottom:.8rem">Pachet Premium — 790 RON ⭐</h3>
        <ul style="color:var(--text-muted);line-height:2;list-style:none;padding:0;margin:0">
          <li>✅ 3 ore animator profesionist</li>
          <li>✅ Tot ce include Classic</li>
          <li>✅ Arcadă din baloane tematică</li>
          <li>✅ Prezentare PPT tematică</li>
          <li>✅ Joc special cu premii</li>
          <li>✅ Playlist muzical tematic</li>
          <li>✅ Poze profesionale (20 poze)</li>
        </ul>
      </div>
      <div style="background:rgba(100,200,255,0.05);border-radius:12px;padding:1.5rem;border:1px solid rgba(100,200,255,0.2)">
        <h3 style="font-size:1.1rem;font-weight:800;color:#64c8ff;margin-bottom:.8rem">Pachet VIP — 1.290 RON 👑</h3>
        <ul style="color:var(--text-muted);line-height:2;list-style:none;padding:0;margin:0">
          <li>✅ 3 ore + 2 animatori</li>
          <li>✅ Tot ce include Premium</li>
          <li>✅ Scaun regal aniversar</li>
          <li>✅ Coroană/accesorii tematice</li>
          <li>✅ Mini-spectacol de scamatorii</li>
          <li>✅ Tort decorat tematic inclus</li>
          <li>✅ Sesiune foto & video 30 min</li>
        </ul>
      </div>
    </div>
    <p style="color:var(--text-muted);line-height:1.9">Prețurile listate sunt valabile pentru petrecerile desfășurate în zona metropolitană (cu taxă deplasare 30 RON dacă locația este în afara limitelor administrative ale Bucureștiului). Plata se face 30% avans la rezervare (online sau cash la sediu) și 70% în ziua evenimentului.</p>
  </div>
</section>

<section class="extra-content-section" style="padding:3rem 0;background:var(--dark-2,#1a1a2e)">
  <div class="container">
    <h2 style="font-size:1.4rem;font-weight:800;color:var(--text-primary,#fff);margin-bottom:1.5rem">Întrebări frecvente — Animatori petreceri copii București & Ilfov</h2>
    <div style="display:flex;flex-direction:column;gap:1rem" itemscope itemtype="https://schema.org/FAQPage">
      <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:1.2rem 1.5rem;border-left:3px solid var(--primary,#ff6b35)" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <p style="font-weight:700;color:#fff;margin:0 0 .5rem" itemprop="name">Cu cât timp înainte trebuie să rezerv animatorul pentru petrecerea în București & Ilfov?</p>
        <p style="color:var(--text-muted);margin:0;line-height:1.8" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer"><span itemprop="text">Recomandam rezervarea cu minimum <strong>2-4 săptămâni</strong> înainte pentru weekend-urile normale. Pentru weekend-urile aglomerate (poate contura de 8 Martie, Paște, 1 Iunie, toamnă-back to school), recomandăm rezervare cu 1-2 luni înainte. Pentru petrecerile de Crăciun/Mos Crăciun, rezervările se deschid din august și se epuizează rapid. Verifici disponibilitatea gratuit, fără angajament, cu un mesaj WhatsApp la 0722 744 377.</span></p>
      </div>
      <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:1.2rem 1.5rem;border-left:3px solid var(--primary,#ff6b35)" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <p style="font-weight:700;color:#fff;margin:0 0 .5rem" itemprop="name">Ce vârstă trebuie să aibă copiii pentru ca evenimentul să fie reușit?</p>
