---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import testimonialsData from '../../data/superparty_testimonials.json';

export async function getStaticPaths() {
  const articles = await getCollection('seo-articles');
  return articles.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Strict Testimonial Logic
const siteTestimonials = testimonialsData.filter((t: any) => t.siteId === 'superparty');
const pageTestimonials = siteTestimonials.filter((t: any) => t.slug === entry.slug);
const testimonialsToShow = pageTestimonials.slice(0, 3); // Get up to 3 testimonials

const isHold = entry.data.indexStatus === 'hold';
const robotsProp = isHold ? 'noindex, follow' : undefined;

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "SuperParty",
      "telephone": "+40722123456", // Fixed [TELEFON] placeholder
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "București/Ilfov",
        "addressRegion": "București"
      },
      "url": `https://superparty.ro/petreceri/${entry.slug}`
    },
    {
      "@type": "Article",
      "headline": entry.data.title,
      "description": entry.data.description,
      "datePublished": entry.data.pubDate ? entry.data.pubDate.toISOString() : new Date().toISOString(),
      "author": { "@type": "Organization", "name": "SuperParty" }
    },
    // Add Review schema for each testimonial
    ...testimonialsToShow.map((t: any) => ({
      "@type": "Review",
      "itemReviewed": {
        "@type": "LocalBusiness",
        "name": "SuperParty",
        "url": `https://superparty.ro/petreceri/${entry.slug}`
      },
      "reviewRating": {
        "@type": "Rating",
        "ratingValue": "5" // Assuming all testimonials are 5-star
      },
      "author": {
        "@type": "Person",
        "name": t.name
      },
      "reviewBody": t.text,
      "datePublished": t.date // Use the testimonial's date
    }))
  ]
};

---

<Layout 
  title={entry.data.title} 
  description={entry.data.description} 
  robots={robotsProp} 
  canonical={entry.data.canonical}
  schema={JSON.stringify(schemaData)}>
	
  <div class="relative bg-white pt-10 pb-20 lg:pt-16 lg:pb-28">
    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-pink-600 font-bold tracking-wider uppercase text-sm border border-pink-200 bg-pink-50 px-3 py-1 rounded-full mb-4 inline-block">
          Experiență Premium
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight mb-4">
          {entry.data.title}
        </h1>
        <p class="text-xl text-gray-500 max-w-2xl mx-auto">
          {entry.data.description}
        </p>
      </div>

      <div class="bg-white rounded-3xl shadow-xl shadow-pink-500/5 ring-1 ring-gray-100 overflow-hidden">
        <div class="prose prose-lg prose-pink max-w-none p-8 md:p-12 lg:p-16">
          <article class="prose">
            <Content />
          </article>
          
          {testimonialsToShow.length > 0 && (
            <div class="mt-12 p-8 bg-pink-50 rounded-2xl border border-pink-100">
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Feedback de la Părinți</h3>
              {testimonialsToShow.map((testimonial: any) => (
                <div class="mb-6 last:mb-0">
                  <blockquote class="italic text-gray-700 text-lg border-l-4 border-pink-400 pl-4 py-2 my-4">
                    "{testimonial.text}"
                  </blockquote>
                  <div class="flex items-center justify-between mt-4">
                    <div class="text-sm font-semibold text-gray-900">{testimonial.name} <span class="text-gray-500 font-normal">| {testimonial.event}</span></div>
                    <div class="text-xs text-gray-400 capitalize">Verificat prin {testimonial.source} - {testimonial.date}</div>
                  </div>
                </div>
              ))}
            </div>
          )}
          
        </div>
      </div>
    </div>
  </div>

</Layout>
```
