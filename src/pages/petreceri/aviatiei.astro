---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('aviatiei') ||
    article.slug.toLowerCase().includes('sector-1') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Aviației, Sectorul 1, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Aviației | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Aviației, Sectorul 1, Bucuresti","url":"https://www.superparty.ro/petreceri/aviatiei"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Veniti la Promenada Mall pentru petreceri?","acceptedAnswer":{"@type":"Answer","text":"Avem experienta cu petrecerile in zona Promenada Mall. Lucram cu sali private din incinta sau in restaurantele din mall."}},
      {"@type":"Question","name":"Animatorii comunica si in engleza pentru famliiile de expati din Pipera?","acceptedAnswer":{"@type":"Answer","text":"Da — avem animatori bilingvi (romana/engleza) disponibili pentru petrecerile in zona Pipera, Aviatorilor, Baneasa unde sunt multi expati."}},
      {"@type":"Question","name":"Ce pachete preferati familiile din Aviatorilor/Pipera?","acceptedAnswer":{"@type":"Answer","text":"Pachetele premium sunt cele mai alese: Super 3 (840 RON) si Super 7 (1290 RON). Acestea includ 2+ personaje si 2-3 ore de program complet."}},
      {"@type":"Question","name":"Cat costa un animator pentru o villa party in Pipera?","acceptedAnswer":{"@type":"Answer","text":"Pachetele raman aceleasi: 490 / 840 / 1290 RON. Indiferent de locatie (vila, apartament sau sala), pretul pachetului nu se schimba."}},
      {"@type":"Question","name":"Aveti experienta cu petreceri tematice sofisticate in Aviatorilor?","acceptedAnswer":{"@type":"Answer","text":"Da — facem petreceri tematice complete: decor, personaj coordonat, jocuri tematice. Contactati-ne pentru pachete custom."}},
      {"@type":"Question","name":"Exista taxa de deplasare din Aviatorilor pana la Voluntari sau Pipera (Ilfov)?","acceptedAnswer":{"@type":"Answer","text":"Nu — acoperim toata zona Aviatorilor, Pipera si Voluntari fara taxa suplimentara de transport."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 1","item":"https://www.superparty.ro/petreceri/sector-1"},
      {"@type":"ListItem","position":4,"name":"Aviației","item":"https://www.superparty.ro/petreceri/aviatiei"}
    ]}
  ]
});
---

<Layout
  title="Animatori Petreceri Copii Aviației Bucuresti | SuperParty — de la 490 RON"
  description="Animatori profesionisti pentru petreceri copii in Aviației, Sectorul 1. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/aviatiei"
  schema={schema}
>
<style>
  .hero{padding:4.5rem 0 3rem;background:radial-gradient(ellipse at top,rgba(255,107,53,.12) 0%,transparent 60%)}
  .hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;margin-bottom:1rem;line-height:1.2}
  .hero .lead{color:var(--text-muted);font-size:1.05rem;max-width:650px;line-height:1.8;margin-bottom:2rem}
  .btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-p{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;padding:.9rem 2rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;transition:transform .2s}
  .btn-p:hover{transform:translateY(-2px)}
  .btn-wa{background:#25d366;color:#fff;padding:.9rem 1.8rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem}
  .sec{padding:3.5rem 0}.sec-alt{padding:3.5rem 0;background:var(--dark-2)}
  .sec-title{font-size:1.6rem;font-weight:800;margin-bottom:.5rem}.sec-sub{color:var(--text-muted);margin-bottom:2rem}
  .grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
  .card{background:var(--dark-3);border:1px solid rgba(255,107,53,.15);border-radius:14px;padding:1.5rem}
  .card h3{font-weight:700;margin-bottom:.8rem;font-size:1rem}
  .card ul{list-style:none;padding:0;margin:0}
  .card li{padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.88rem;color:var(--text-muted);line-height:1.5}
  .card li:last-child{border:0}
  .pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem}
  .pkg{background:var(--dark-3);border:2px solid rgba(255,107,53,.2);border-radius:18px;padding:2rem;text-align:center}
  .pkg.featured{border-color:var(--primary);background:rgba(255,107,53,.08)}
  .pkg-title{font-size:1.2rem;font-weight:800;margin-bottom:.4rem}
  .pkg-price{font-size:2rem;font-weight:900;color:var(--primary);margin:.5rem 0}
  .pkg-desc{font-size:.88rem;color:var(--text-muted);line-height:1.6}
  .pkg-badge{background:var(--primary);color:#fff;font-size:.7rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;display:inline-block;margin-bottom:.5rem}
  .art-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .art-card{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.2rem;text-decoration:none;color:var(--text);transition:border-color .2s}
  .art-card:hover{border-color:var(--primary)}
  .art-card h3{font-size:.95rem;font-weight:700;color:var(--primary);margin-bottom:.4rem}
  .art-card p{font-size:.82rem;color:var(--text-muted)}
  .faq-list{display:flex;flex-direction:column;gap:1rem;max-width:780px}
  .faq-item{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.4rem}
  .faq-item h3{font-size:.95rem;font-weight:700;margin-bottom:.6rem}
  .faq-item p{font-size:.9rem;color:var(--text-muted);line-height:1.7}
  .breadcrumb{font-size:.82rem;color:var(--text-muted);margin-bottom:1.5rem}
  .breadcrumb a{color:var(--primary);text-decoration:none}
  .cta-box{background:linear-gradient(135deg,rgba(255,107,53,.15),rgba(255,107,53,.05));border:1px solid rgba(255,107,53,.25);border-radius:20px;padding:3rem 2rem;text-align:center}
  .cta-box h2{font-size:1.7rem;font-weight:800;margin-bottom:1rem}
  .cta-box p{color:var(--text-muted);margin-bottom:2rem}
  .nav-links{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-top:1.5rem;font-size:.9rem}
  .nav-links a{color:var(--primary);font-weight:600;text-decoration:none}
  .rich-text{max-width:780px}
  .rich-text p{color:var(--text-muted);line-height:1.9;margin-bottom:1rem}
  .rich-text strong{color:var(--text)}
  @media(max-width:600px){.btns{flex-direction:column}}
</style>

<section class="hero">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Acasa</a> › <a href="/animatori-petreceri-copii">Animatori Petreceri Copii</a> › <a href="/petreceri/sector-1">Sectorul 1</a> › Aviației
    </nav>
    <h1>Animatori Petreceri Copii<br><span style="color:var(--primary)">Aviației, Bucuresti</span></h1>
    <p class="lead">SuperParty este echipa #1 de animatori pentru petreceri copii din <strong>Aviației</strong>, cartier de nord al Bucurestiului cu comunitate internationala si corporatista, zone rezidentiale premium si hub-ul de afaceri Pipera, cu standarde ridicate pentru servicii de animatie. Peste 10.000 de petreceri din 2018, garantie contractuala unica in piata, 1498 de recenzii de 5 stele.</p>
    <div class="btns">
      <a href="tel:+40722744377" class="btn-p cta">📞 Rezerva: 0722 744 377</a>
      <a href="https://wa.me/40722744377" class="btn-wa cta">💬 WhatsApp rapid</a>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="grid-3">
      <div class="card">
        <h3>📍 Zone si repere Aviației</h3>
        <ul><li>📍 Promenada Mall - mall premium cu entertainment</li>
<li>📍 Parcul Herastrau - la 5 minute (cel mai mare parc din Bucuresti)</li>
<li>📍 Turnuri Pipera - zona de business premium</li>
<li>📍 Soseaua Nordului - zona de restaurante de lux</li>
<li>📍 Aeroportul Baneasa (fostul aeroport, acum inchis) - reper geografic</li></ul>
      </div>
      <div class="card">
        <h3>⏱ Acces si transport</h3>
        <ul>
          <li>🚗 ~20 min din centru, 5 min din Floreasca</li>
          <li>🚍 Metrou M2 (statia Aurel Vlaicu/Aviatorilor); autobuze 301, 306, 312; acces excelent auto via Soseaua Nordului</li>
          <li>✅ Animatorul soseste cu 10 min inainte</li>
          <li>✅ Transport gratuit in Aviației</li>
          <li><a href="/petreceri/sector-1" style="color:var(--primary)">→ Toate zonele Sector 1</a></li>
        </ul>
      </div>
      <div class="card">
        <h3>🎉 Sali recomandate Aviației</h3>
        <ul><li>🎉 Promenada Events (in cadrul mallului)</li>
<li>🎉 Restaurante premium in zona Aviatorilor (Crystal Palace, Fratelli)</li>
<li>🎉 Vile private cu gradina in zona Pipera/Aviatie</li></ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Pachete animatori <span style="color:var(--primary)">disponibile in Aviației</span></h2>
    <p class="sec-sub">Preturi garantate contractual. Fara taxe ascunse.</p>
    <div class="pkg-grid">
      <div class="pkg">
        <div class="pkg-title">Super 1</div>
        <div class="pkg-price">490 RON</div>
        <div class="pkg-desc">1 personaj costumat · 2 ore<br>Jocuri, baloane, face painting, mini disco<br>Transport gratuit in Aviației</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg featured">
        <div class="pkg-badge">⭐ CEL MAI ALES</div>
        <div class="pkg-title">Super 3</div>
        <div class="pkg-price">840 RON</div>
        <div class="pkg-desc">2 personaje costumati · 2 ore<br>Jocuri duble, baloane complexe, diplome<br>Transport gratuit in Aviației</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg">
        <div class="pkg-title">Super 7</div>
        <div class="pkg-price">1290 RON</div>
        <div class="pkg-desc">1 animator + 4 ursitoare · 3 ore<br>Botez sau aniversare mare<br>Transport gratuit in Aviației</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:1.5rem;color:var(--text-muted);font-size:.9rem">
      <a href="/animatori-petreceri-copii" style="color:var(--primary);font-weight:600">→ Toate detaliile pachetelor pe pagina principala</a>
    </p>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Locatii pentru petreceri copii în <span style="color:var(--primary)">Aviației</span></h2>
    <div class="rich-text">
      <p>Zona Aviatorilor-Pipera are cele mai moderne locatii pentru petreceri de copii din nordul Capitalei. <strong>Promenada Mall</strong> (lifestyle mall premium) are sala events disponibila pentru rezervare si restaurante cu sali private elegante — destinatia indoor nr. 1 din zona.</p>
<p><strong>Vilele cu gradina din Pipera</strong> sunt destinatia de top pentru petreceri private vara — gradini spatioase cu zona verde, terasa si uneori piscina. SuperParty are experienta cu zeci de petreceri la vile din aceasta zona si stie cum sa organizeze programul pentru maximum de impact.</p>
<p><strong>Parcul Herastrau</strong> (186 ha, la 5-10 minute) este optiunea naturala premium pentru petreceri mari. <strong>Hotelurile din zona Nord</strong> (Novotel, Intercontinental) accepta petreceri private pentru copii cu animator extern — avem experienta cu aceste locatii si cu clientii internationali.</p>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Personaje si teme populare în <span style="color:var(--primary)">Aviației</span></h2>
    <div class="rich-text">
      <p>Zona Aviatorilor-Pipera este internationala — multi expati, romani cu experienta in strainatate. <strong>Personaje universale top:</strong> Elsa, Spider-Man, Iron Man, Rapunzel. <strong>Cerere specifica expati:</strong> Peppa Pig (familii britanice), Bluey (australieni si UK), PJ Masks (francofoni), personaje Netflix internationale.</p>
<p><strong>Animatori bilingvi</strong> disponibili la cerere — jocurile, cantecele si ghicitorile pot fi desfasurate in engleza, romana sau mixt. Ideal pentru petrecerile mixte romano-internationale. Rezervati animatorul bilingv cu minim 3 saptamani inainte.</p>
<p><strong>Teme premium cerute in Pipera:</strong> Science & Discovery Party (experiente stiintifice wow), Art Attack premium (pictura, sculptura in argila), Chef Party (copiii gatesc pizza sau prajituri), Treasure Hunt tematic cu povestire si costumatii.</p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Cum organizezi petrecerea perfecta în <span style="color:var(--primary)">Aviației</span></h2>
    <div class="rich-text">
      <p><strong>Trafic Pipera:</strong> Zona este aglomerata 16-20 in zilele lucratoare. Petrecerile de sambata sau duminica, sau dupa 19:00 in saptamana, evita complet embouteillage-ul. Animatorul pleaca cu rezerva de 45 min pentru a fi sigur ca ajunge la timp.</p>
<p><strong>Acces la complexe/vile:</strong> Comunicati-ne cu 24h inainte codul de acces sau datele de intrare in complex. Animatorul ajunge cu 10 min inainte, direct la usa.</p>
<p><strong>Pachete recomandate:</strong> Super 3 (2 personaje, 840 RON) sau Super 7 (3 ore, 1290 RON). Familiile din Pipera prefera calitate maxima fara compromis. Optional: fotograf profesional la cerere (partener SuperParty). Rezerva: 0722 744 377.</p>
    </div>
  </div>
</section>

{hubArticles.length > 0 && (
<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Idei petreceri copii <span style="color:var(--primary)">Aviației</span></h2>
    <p class="sec-sub">Articole si ghiduri utile.</p>
    <div class="art-grid">
      {hubArticles.map(article => (
        <a href={'/petreceri/' + article.slug} class="art-card">
          <h3>{article.data.title}</h3>
          <p>{article.data.description?.slice(0,100)}...</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<section class="sec" itemscope itemtype="https://schema.org/FAQPage">
