---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('berceni') ||
    article.slug.toLowerCase().includes('sector-4') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Berceni, Sectorul 4, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Berceni | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Berceni, Sectorul 4, Bucuresti","url":"https://www.superparty.ro/petreceri/berceni"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Veniti in Berceni pentru petreceri de copii?","acceptedAnswer":{"@type":"Answer","text":"Da — Berceni este o zona pe care o acoperim in totalitate. De la Piata Berceni pana la limita cu Jilava, suntem disponibili fara taxa de deplasare."}},
      {"@type":"Question","name":"Ce pachet este recomandat in Berceni?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 1 (490 RON, 1 personaj, 2 ore) este cel mai ales in Berceni. Super 3 (840 RON) este excelent pentru petreceri cu 20+ copii."}},
      {"@type":"Question","name":"Veniti si la case cu curte in Berceni?","acceptedAnswer":{"@type":"Answer","text":"Da — Berceni are si zone cu case. Facem animatie la curte, gradina sau in garaj transformat in sala de petreceri. Animatorul vine cu tot echipamentul."}},
      {"@type":"Question","name":"Cat timp dureaza deplasarea la Berceni?","acceptedAnswer":{"@type":"Answer","text":"Intre 15-25 minute din centrul Bucurestiului, in functie de trafic. Animatorul soseste cu 10 minute inainte de inceperea programului."}},
      {"@type":"Question","name":"Exista animatori disponibili sambata si duminica in Berceni?","acceptedAnswer":{"@type":"Answer","text":"Da, dar rezervati devreme. Weekendurile sunt cele mai solicitate — recomandam rezervare cu 2-3 saptamani inainte."}},
      {"@type":"Question","name":"Aveti personaje mai speciale, nu doar Spider-Man si Elsa?","acceptedAnswer":{"@type":"Answer","text":"Avem 50+ personaje: Mos Craciun, Elsa, Rapunzel, Belle, Ariel, Batman, Captain America, Iron Man, Spider-Man, Sonic, PAW Patrol, Minnie, Winnie, Clown, si altele."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 4","item":"https://www.superparty.ro/petreceri/sector-4"},
      {"@type":"ListItem","position":4,"name":"Berceni","item":"https://www.superparty.ro/petreceri/berceni"}
    ]}
  ]
});
