---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('colentina') ||
    article.slug.toLowerCase().includes('sector-2') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Colentina, Sectorul 2, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Colentina | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Colentina, Sectorul 2, Bucuresti","url":"https://www.superparty.ro/petreceri/colentina"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Acoperiti toata zona Colentina, inclusiv Fundeni?","acceptedAnswer":{"@type":"Answer","text":"Da — acoperim intreaga Soseaua Colentina de la intrare pana la Fundeni si dincolo. Nu exista taxa de deplasare in aceasta zona."}},
      {"@type":"Question","name":"Veniti la petreceri langa lacurile din Colentina?","acceptedAnswer":{"@type":"Answer","text":"Da — facem animatie si in aer liber. Lacul Fundeni si parcurile din Colentina sunt locatii populare pentru petreceri de vara cu animatori."}},
      {"@type":"Question","name":"Ce pachete sunt disponibile in Colentina?","acceptedAnswer":{"@type":"Answer","text":"Toate pachetele: Super 1 (490 RON), Super 3 (840 RON) si Super 7 (1290 RON). Alegeti in functie de numarul de copii si durata dorita."}},
      {"@type":"Question","name":"Cum ajungeti cel mai usor in Colentina?","acceptedAnswer":{"@type":"Answer","text":"Animatorii nostri se deplaseaza cu masina proprie direct la adresa ta. Soseaua Colentina este bine acoperita de toate rutele noastre."}},
      {"@type":"Question","name":"Exista sali de petreceri recomandate in Colentina?","acceptedAnswer":{"@type":"Answer","text":"Da — avem relatii cu mai multe sali din zona Colentina si Fundeni. Contactati-ne si va putem recomanda in functie de buget si numarul de copii."}},
      {"@type":"Question","name":"Cat dureaza un program de animatie standard in Colentina?","acceptedAnswer":{"@type":"Answer","text":"Programul standard dureaza 2 ore (pachetul Super 1 sau Super 3). Poate fi extins la 3 ore cu pachetul Super 7 sau la cerere."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 2","item":"https://www.superparty.ro/petreceri/sector-2"},
      {"@type":"ListItem","position":4,"name":"Colentina","item":"https://www.superparty.ro/petreceri/colentina"}
    ]}
  ]
});
---

<Layout
  title="Animatori Petreceri Copii Colentina | SuperParty"
  description="Animatori profesionisti pentru petreceri copii in Colentina, Sectorul 2. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/colentina"
  schema={schema}
