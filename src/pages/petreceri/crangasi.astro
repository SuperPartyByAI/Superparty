---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('crangasi') ||
    article.slug.toLowerCase().includes('sector-6') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Crangasi, Sectorul 6, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Crangasi | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Crangasi, Sectorul 6, Bucuresti","url":"https://www.superparty.ro/petreceri/crangasi"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Veniti la Lacul Crangasi pentru petreceri?","acceptedAnswer":{"@type":"Answer","text":"Da — lacul si parcul din zona sunt locatii excelente pentru petreceri in aer liber. Animatorul vine cu echipament portabil complet."}},
      {"@type":"Question","name":"Cat costa deplasarea pana la Crangasi?","acceptedAnswer":{"@type":"Answer","text":"Transportul este inclus in pretul pachetului. Nu exista taxa de deplasare pentru zona Crangasi, Sectorul 6."}},
      {"@type":"Question","name":"Ce pachet recomandati pentru o petrecere in apartament in Crangasi?","acceptedAnswer":{"@type":"Answer","text":"Super 1 (490 RON) este ideal pentru apartamente — 1 personaj si 2 ore de program adaptat spatiului disponibil."}},
      {"@type":"Question","name":"Aveti animatori familiari cu zona Crangasi?","acceptedAnswer":{"@type":"Answer","text":"Da — unii din animatorii nostri locuiesc in zona Crangasi, asa ca nu se vor pierde niciodata."}},
      {"@type":"Question","name":"Sunt disponibili animatorii in Crangasi sambata dimineata?","acceptedAnswer":{"@type":"Answer","text":"Da — avem disponibilitate toata ziua sambata si duminica, inclusiv dimineata de la 10:00."}},
      {"@type":"Question","name":"Puteti face si un program de botez in Crangasi?","acceptedAnswer":{"@type":"Answer","text":"Da — pachetul Super 7 (1290 RON) include 1 animator + 4 ursitoare pentru botez, 3 ore de program complet. Il recomandam pentru botezuri."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 6","item":"https://www.superparty.ro/petreceri/sector-6"},
      {"@type":"ListItem","position":4,"name":"Crangasi","item":"https://www.superparty.ro/petreceri/crangasi"}
    ]}
  ]
});
---

<Layout
  title="Animatori Petreceri Copii Crangasi Bucuresti | SuperParty — de la 490 RON"
  description="Animatori profesionisti pentru petreceri copii in Crangasi, Sectorul 6. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/crangasi"
  schema={schema}
>
<style>
  .hero{padding:4.5rem 0 3rem;background:radial-gradient(ellipse at top,rgba(255,107,53,.12) 0%,transparent 60%)}
  .hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;margin-bottom:1rem;line-height:1.2}
  .hero .lead{color:var(--text-muted);font-size:1.05rem;max-width:650px;line-height:1.8;margin-bottom:2rem}
  .btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-p{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;padding:.9rem 2rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;transition:transform .2s}
  .btn-p:hover{transform:translateY(-2px)}
  .btn-wa{background:#25d366;color:#fff;padding:.9rem 1.8rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem}
  .sec{padding:3.5rem 0}.sec-alt{padding:3.5rem 0;background:var(--dark-2)}
  .sec-title{font-size:1.6rem;font-weight:800;margin-bottom:.5rem}.sec-sub{color:var(--text-muted);margin-bottom:2rem}
  .grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
  .card{background:var(--dark-3);border:1px solid rgba(255,107,53,.15);border-radius:14px;padding:1.5rem}
  .card h3{font-weight:700;margin-bottom:.8rem;font-size:1rem}
  .card ul{list-style:none;padding:0;margin:0}
  .card li{padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.88rem;color:var(--text-muted);line-height:1.5}
  .card li:last-child{border:0}
  .pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem}
  .pkg{background:var(--dark-3);border:2px solid rgba(255,107,53,.2);border-radius:18px;padding:2rem;text-align:center}
  .pkg.featured{border-color:var(--primary);background:rgba(255,107,53,.08)}
  .pkg-title{font-size:1.2rem;font-weight:800;margin-bottom:.4rem}
  .pkg-price{font-size:2rem;font-weight:900;color:var(--primary);margin:.5rem 0}
  .pkg-desc{font-size:.88rem;color:var(--text-muted);line-height:1.6}
  .pkg-badge{background:var(--primary);color:#fff;font-size:.7rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;display:inline-block;margin-bottom:.5rem}
  .art-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .art-card{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.2rem;text-decoration:none;color:var(--text);transition:border-color .2s}
  .art-card:hover{border-color:var(--primary)}
  .art-card h3{font-size:.95rem;font-weight:700;color:var(--primary);margin-bottom:.4rem}
  .art-card p{font-size:.82rem;color:var(--text-muted)}
  .faq-list{display:flex;flex-direction:column;gap:1rem;max-width:780px}
  .faq-item{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.4rem}
  .faq-item h3{font-size:.95rem;font-weight:700;margin-bottom:.6rem}
  .faq-item p{font-size:.9rem;color:var(--text-muted);line-height:1.7}
  .breadcrumb{font-size:.82rem;color:var(--text-muted);margin-bottom:1.5rem}
  .breadcrumb a{color:var(--primary);text-decoration:none}
  .cta-box{background:linear-gradient(135deg,rgba(255,107,53,.15),rgba(255,107,53,.05));border:1px solid rgba(255,107,53,.25);border-radius:20px;padding:3rem 2rem;text-align:center}
  .cta-box h2{font-size:1.7rem;font-weight:800;margin-bottom:1rem}
  .cta-box p{color:var(--text-muted);margin-bottom:2rem}
  .nav-links{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-top:1.5rem;font-size:.9rem}
  .nav-links a{color:var(--primary);font-weight:600;text-decoration:none}
  .rich-text{max-width:780px}
  .rich-text p{color:var(--text-muted);line-height:1.9;margin-bottom:1rem}
  .rich-text strong{color:var(--text)}
  @media(max-width:600px){.btns{flex-direction:column}}
</style>

<section class="hero">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Acasa</a> › <a href="/animatori-petreceri-copii">Animatori Petreceri Copii</a> › <a href="/petreceri/sector-6">Sectorul 6</a> › Crangasi
    </nav>
    <h1>Animatori Petreceri Copii<br><span style="color:var(--primary)">Crangasi, Bucuresti</span></h1>
    <p class="lead">SuperParty este echipa #1 de animatori pentru petreceri copii din <strong>Crangasi</strong>, cartier linistit si verde din vestul Bucurestiului cu Lacul Crangasi, Parcul Crangasi si o comunitate stabila de familii care apreciaza serviciile de calitate. Peste 10.000 de petreceri din 2018, garantie contractuala unica in piata, 1498 de recenzii de 5 stele.</p>
    <div class="btns">
      <a href="tel:+40722744377" class="btn-p cta">📞 Rezerva: 0722 744 377</a>
      <a href="https://wa.me/40722744377" class="btn-wa cta">💬 WhatsApp rapid</a>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="grid-3">
      <div class="card">
        <h3>📍 Zone si repere Crangasi</h3>
        <ul><li>📍 Lacul Crangasi - 42 hectare, spatiu natural relaxant</li>
<li>📍 Parcul Crangasi - spatiu verde amenajat cu loc de joaca</li>
<li>📍 Statia de metrou Crangasi M1 - acces rapid</li>
<li>📍 Bulevardul Constructorilor - artera principala</li>
<li>📍 Centrul Comercial Crangasi Shopping</li></ul>
      </div>
      <div class="card">
        <h3>⏱ Acces si transport</h3>
        <ul>
          <li>🚗 ~20 min din centru</li>
          <li>🚍 Metrou M1 (statia Crangasi) — acces excelent; autobuze 122, 170; tramvaie 41</li>
          <li>✅ Animatorul soseste cu 10 min inainte</li>
          <li>✅ Transport gratuit in Crangasi</li>
          <li><a href="/petreceri/sector-6" style="color:var(--primary)">→ Toate zonele Sector 6</a></li>
        </ul>
      </div>
      <div class="card">
        <h3>🎉 Sali recomandate Crangasi</h3>
        <ul><li>🎉 Sala de petreceri la Crangasi Shopping</li>
<li>🎉 Restaurante cu sali private pe B-dul Constructorilor</li>
<li>🎉 Centrul de events Crangasi Arena</li></ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Pachete animatori <span style="color:var(--primary)">disponibile in Crangasi</span></h2>
    <p class="sec-sub">Preturi garantate contractual. Fara taxe ascunse.</p>
    <div class="pkg-grid">
      <div class="pkg">
        <div class="pkg-title">Super 1</div>
        <div class="pkg-price">490 RON</div>
        <div class="pkg-desc">1 personaj costumat · 2 ore<br>Jocuri, baloane, face painting, mini disco<br>Transport gratuit in Crangasi</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg featured">
        <div class="pkg-badge">⭐ CEL MAI ALES</div>
        <div class="pkg-title">Super 3</div>
        <div class="pkg-price">840 RON</div>
        <div class="pkg-desc">2 personaje costumati · 2 ore<br>Jocuri duble, baloane complexe, diplome<br>Transport gratuit in Crangasi</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg">
        <div class="pkg-title">Super 7</div>
        <div class="pkg-price">1290 RON</div>
        <div class="pkg-desc">1 animator + 4 ursitoare · 3 ore<br>Botez sau aniversare mare<br>Transport gratuit in Crangasi</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:1.5rem;color:var(--text-muted);font-size:.9rem">
      <a href="/animatori-petreceri-copii" style="color:var(--primary);font-weight:600">→ Toate detaliile pachetelor pe pagina principala</a>
    </p>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Locatii pentru petreceri copii în <span style="color:var(--primary)">Crangasi</span></h2>
    <div class="rich-text">
      <p><strong>Lacul Crangasi</strong> (42 ha) cu parcul adiacent este destinatia naturala de vara numarul 1 in vestul Capitalei. SuperParty organizeaza petreceri chiar la malul lacului: animatie pe iarba, sub salcii, cu vedere la lac. Copiii se joaca liber in natura in timp ce animatorul coordoneaza jocuri interactive.</p>
<p>Pentru interior: <strong>Crangasi Shopping Center</strong> are restaurante cu sali private. Pe <strong>Bulevardul Constructorilor</strong>: Magic World Crangasi si Fun Zone Club — trambulina, zona moale, sistem audio inclus. Apartamentele din Crangasi sunt spatioase (blocuri 70-80) — potrivite pentru 15-25 copii fara sala dedicata.</p>
<p>Avantaj logistic: <strong>Statia metrou M1 Crangasi</strong> este la 3 minute de mers — invitatii din orice zona a Capitalei ajung rapid si usor. Animatorul nostru vine si cu masina proprie pentru transport echipament.</p>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Personaje si teme populare în <span style="color:var(--primary)">Crangasi</span></h2>
    <div class="rich-text">
      <p><strong>Personaje preferate in Crangasi:</strong> Elsa si Minnie Mouse (fetite), Spider-Man si Batman (baieti), PAW Patrol (mixt 3-5 ani). Tendinte 2025: Bluey explozie la 2-4 ani, Mighty Morphin Power Rangers revine la 6-9 ani.</p>
<p>Parintii din Crangasi apreciaza <strong>calitate la pret corect</strong> — nu cel mai ieftin, dar cel mai bun raport. SuperParty livreaza exact asta: costum impecabil, animator cu energie si experienta, program structurat fara momente moarte.</p>
<p>Cel mai asteptat moment la petrecerile din Crangasi: <strong>modelarea baloanelor</strong> — copiii comanda baloane elaborate (animale, castele, personaje). Animatorul face fata celor mai creative cereri. Al doilea loc: <strong>face painting</strong> cu modele complete pe obraz si maini.</p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Cum organizezi petrecerea perfecta în <span style="color:var(--primary)">Crangasi</span></h2>
    <div class="rich-text">
      <p><strong>La Lacul Crangasi vara:</strong> Veniti cu 30 min inainte sa alegeti zona cu umbra (salciile de la mal sunt ideale). Nu e nevoie de rezervare sau autorizatie pentru grupuri sub 30 persoane. Stabiliti un punct de intalnire clar si communicati GPS invitatilor.</p>
<p><strong>Acasa:</strong> Animatorul evalueaza spatiul la sosire si adapteaza programul. Sufragerie 20mp + hol = suficient pentru 12-15 copii activi. Program exact 2 ore: intrare dramatica (5 min), jocuri (40 min), baloane (15 min), face painting (30 min), disco+tort (20 min), fotografii (5 min).</p>
<p><strong>Rezervare:</strong> Telefon sau WhatsApp la 0722 744 377. Confirmam in 30 minute, contract in 24 ore. Plata dupa petrecere — garantie contractuala completa.</p>
    </div>
  </div>
</section>

{hubArticles.length > 0 && (
<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Idei petreceri copii <span style="color:var(--primary)">Crangasi</span></h2>
    <p class="sec-sub">Articole si ghiduri utile.</p>
    <div class="art-grid">
      {hubArticles.map(article => (
        <a href={'/petreceri/' + article.slug} class="art-card">
          <h3>{article.data.title}</h3>
          <p>{article.data.description?.slice(0,100)}...</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<section class="sec" itemscope itemtype="https://schema.org/FAQPage">
  <div class="container">
    <h2 class="sec-title">Intrebari frecvente — animatori <span style="color:var(--primary)">Crangasi</span></h2>
    <div class="faq-list">

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Veniti la Lacul Crangasi pentru petreceri?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
