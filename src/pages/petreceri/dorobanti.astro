import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('dorobanti') ||
    article.slug.toLowerCase().includes('sector-1') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Dorobanți, Sectorul 1, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Dorobanți | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Dorobanți, Sectorul 1, Bucuresti","url":"https://www.superparty.ro/petreceri/dorobanti"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Veniti la petreceri in zona Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Da — Dorobantii este una din zonele noastre premium preferate. Avem experienta cu petreceri la vile, gradini si restaurante din aceasta zona eleganta."}},
      {"@type":"Question","name":"Ce personaje Disney sunt disponibile pentru familiile din Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Avem toata gama Disney: Elsa, Anna, Rapunzel, Belle, Aurora, Ariel, Merida, Moana (printe) si Spider-Man, Batman, Thor (supereroi). Plus multe altele."}},
      {"@type":"Question","name":"Costumele sunt la standardele familiilor din Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Da — costumele SuperParty sunt licentiate Disney/Marvel si confectionate din tesaturi premium. Sunt perfecte pentru orice tip de eveniment, inclusiv cele mai pretentioase."}},
      {"@type":"Question","name":"Organizati petreceri si la restaurantele fine dining din Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Lucram cu orice locatie. Coordonati cu restaurantul si cu noi in avans, si animatorul se va adapta perfect la spatiu si program."}},
      {"@type":"Question","name":"Cat costa un animator pentru o petrecere in zona Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Pachetele raman aceleasi: Super 1 (490 RON), Super 3 (840 RON), Super 7 (1290 RON). Nu exista taxa de deplasare in zona Dorobanti, Sectorul 1."}},
      {"@type":"Question","name":"Aveti disponibilitate sabata la pranz in Dorobanti?","acceptedAnswer":{"@type":"Answer","text":"Da — sabata este ziua cu cea mai mare disponibilitate. Vom rezerva slotul dorit daca rezervati cu cel putin 2-3 saptamani inainte."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 1","item":"https://www.superparty.ro/petreceri/sector-1"},
      {"@type":"ListItem","position":4,"name":"Dorobanți","item":"https://www.superparty.ro/petreceri/dorobanti"}
    ]}
  ]
});
