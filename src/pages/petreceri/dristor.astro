import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('dristor') ||
    article.slug.toLowerCase().includes('sector-3') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Dristor, Sectorul 3, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
