import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('floreasca') ||
    article.slug.toLowerCase().includes('sector-2') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Floreasca, Sectorul 2, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Floreasca | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Floreasca, Sectorul 2, Bucuresti","url":"https://www.superparty.ro/petreceri/floreasca"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Aveti experienta cu petreceri la vile in Floreasca?","acceptedAnswer":{"@type":"Answer","text":"Da — Floreasca si zona Herastrau reprezinta una din specialitatile noastre. Avem experienta cu petreceri la vile private, gradini si terase de lux."}},
      {"@type":"Question","name":"Ce pachete recomandati pentru zona Floreasca?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 3 (840 RON, 2 personaje, 2 ore) sau Super 7 (1290 RON, animator + 4 ursitoare botez, 3 ore) sunt cele mai alese in Floreasca."}},
      {"@type":"Question","name":"Costumele sunt suficient de calitative pentru familiile din Floreasca?","acceptedAnswer":{"@type":"Answer","text":"Absolut — toate costumele SuperParty sunt licentiate oficial Disney/Marvel si confectionate la standarde premium. Sunt perfecte pentru orice tip de eveniment."}},
      {"@type":"Question","name":"Faceti petreceri si in Parcul Herastrau?","acceptedAnswer":{"@type":"Answer","text":"Da — animatia in aer liber in Parcul Herastrau este posibila (zona verde, nu in locatii inchiriate). Animatorul vine cu echipament portabil complet."}},
      {"@type":"Question","name":"Exista taxa de deplasare pentru Floreasca?","acceptedAnswer":{"@type":"Answer","text":"Nu — transportul este inclus in pretul pachetului pentru toata zona Floreasca, Herastrau, Dorobanti, Sectorul 2."}},
      {"@type":"Question","name":"Puteti gestiona o petrecere cu 40-50 copii in Floreasca?","acceptedAnswer":{"@type":"Answer","text":"Da — avem echipe de 2-3 animatori pentru petreceri mari. Pachetul Super 7 sau variante custom sunt disponibile. Contactati-ne pentru oferta detaliata."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 2","item":"https://www.superparty.ro/petreceri/sector-2"},
      {"@type":"ListItem","position":4,"name":"Floreasca","item":"https://www.superparty.ro/petreceri/floreasca"}
    ]}
  ]
});
