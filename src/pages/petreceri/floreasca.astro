<Layout
  title="Animatori Petreceri Copii Floreasca | SuperParty"
  description="Animatori profesionisti pentru petreceri copii in Floreasca, Sectorul 2. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/floreasca"
  schema={schema}
