---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('militari') ||
    article.slug.toLowerCase().includes('sector-6') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "SuperParty — Animatori Petreceri Copii",
      "telephone": "+40722744377",
      "url": "https://www.superparty.ro",
      "areaServed": { "@type": "Place", "name": "Militari, Sectorul 6, Bucuresti" },
      "priceRange": "490-1290 RON",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "1498" }
    },
    {
      "@type": "Service",
      "name": "Animatori Petreceri Copii Militari | SuperParty",
      "provider": { "@type": "LocalBusiness", "name": "SuperParty", "telephone": "+40722744377" },
      "areaServed": "Militari, Sectorul 6, Bucuresti",
      "url": "https://www.superparty.ro/petreceri/militari"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
      {"@type": "Question", "name": "Veniti la Militari Residence pentru petreceri?", "acceptedAnswer": {"@type": "Answer", "text": "Da — Militari Residence este una din destinatiile noastre frecvente. Avem experienta cu regulamentul de acces al complexului si coordonam cu administratia."}},
      {"@type": "Question", "name": "Cat costa un animator in Militari?", "acceptedAnswer": {"@type": "Answer", "text": "De la 490 RON (Super 1, 2 ore, 1 personaj costumat). Transport gratuit in toata zona Militari, Sectorul 6."}},
      {"@type": "Question", "name": "Ce personaje recomandati pentru copiii din Militari?", "acceptedAnswer": {"@type": "Answer", "text": "Depinde de varsta: 2-4 ani — Minnie Mouse, Elsa; 4-7 ani — Spider-Man, Batman, Rapunzel; 7-10 ani — Sonic, PAW Patrol. Avem 50+ personaje."}},
      {"@type": "Question", "name": "Sunt disponibili animatorii in Militari in weekend?", "acceptedAnswer": {"@type": "Answer", "text": "Da, dar rezervati cu 2-3 saptamani inainte. Militari si Militari Residence sunt printre cele mai solicitate zone ale noastre."}},
      {"@type": "Question", "name": "Puteti organiza petreceri in apartamentele din Militari Residence?", "acceptedAnswer": {"@type": "Answer", "text": "Da — vindem la domiciliu in apartamente, sali de bloc sau in spatiile comune ale complexului. Animatorul se adapteaza oricarui spatiu."}},
      {"@type": "Question", "name": "Faceti si decoratiuni pentru petreceri in Militari?", "acceptedAnswer": {"@type": "Answer", "text": "Ne ocupam cu animatia propriu-zisa (personaje, jocuri, face painting, baloane). Pentru decoratiuni vi si aranjamente va recomandam parteneri specializati."}}
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Acasa", "item": "https://www.superparty.ro" },
        { "@type": "ListItem", "position": 2, "name": "Animatori Petreceri Copii", "item": "https://www.superparty.ro/animatori-petreceri-copii" },
        { "@type": "ListItem", "position": 3, "name": "Sectorul 6", "item": "https://www.superparty.ro/petreceri/sector-6" },
        { "@type": "ListItem", "position": 4, "name": "Militari", "item": "https://www.superparty.ro/petreceri/militari" }
      ]
    }
  ]
});
