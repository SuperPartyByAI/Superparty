import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('pantelimon') ||
    article.slug.toLowerCase().includes('sector-2') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Pantelimon (Cartier), Sectorul 2, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Pantelimon (Cartier) | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Pantelimon (Cartier), Sectorul 2, Bucuresti","url":"https://www.superparty.ro/petreceri/pantelimon-cartier"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Acoperiti cartierul Pantelimon din Sectorul 2 (nu Ilfov)?","acceptedAnswer":{"@type":"Answer","text":"Da — acoperim AMBELE Pantelimon: cartierul din Sectorul 2 (Bucuresti) si comuna Pantelimon din Ilfov. Va rugam sa specificati adresa exacta."}},
      {"@type":"Question","name":"Cat costa un animator in cartierul Pantelimon S2?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 1 (490 RON, 2 ore, 1 personaj). Transport gratuit in cartierul Pantelimon, Sectorul 2."}},
      {"@type":"Question","name":"Exista sali de petreceri recomandate in Pantelimon cartier?","acceptedAnswer":{"@type":"Answer","text":"Da — Centrul Comercial Pantelimon are o zona de events, iar pe Soseaua Pantelimon gasiti mai multe restaurante cu sali private. Va putem recomanda in functie de buget."}},
      {"@type":"Question","name":"Veniti si la blocuri din zona Pantelimon?","acceptedAnswer":{"@type":"Answer","text":"Da — facem petreceri in apartamente, curti de bloc sau in orice spatiu disponibil din cartierul Pantelimon."}},
      {"@type":"Question","name":"Aveti animatori care cunosc cartierul Pantelimon?","acceptedAnswer":{"@type":"Answer","text":"Da — avem animatori familiari cu zona. Stiim sa ajungem rapid si fara confuzii intre Pantelimon S2 si Pantelimon Ilfov."}},
      {"@type":"Question","name":"Organizati si petreceri de gradinita/scoala in Pantelimon?","acceptedAnswer":{"@type":"Answer","text":"Da — facem si programe pentru colective mari (clase, grupe de gradinita). Contactati-ne pentru pachete speciale."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 2","item":"https://www.superparty.ro/petreceri/sector-2"},
      {"@type":"ListItem","position":4,"name":"Pantelimon (Cartier)","item":"https://www.superparty.ro/petreceri/pantelimon-cartier"}
    ]}
  ]
});
