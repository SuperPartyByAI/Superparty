      "telephone": "+40722744377",
      "url": "https://www.superparty.ro",
      "areaServed": { "@type": "Place", "name": "Rahova, Sectorul 5, Bucuresti" },
      "priceRange": "490-1290 RON",
      "aggregateRating": { "@type": "AggregateRating", "ratingValue": "5.0", "reviewCount": "1498" }
