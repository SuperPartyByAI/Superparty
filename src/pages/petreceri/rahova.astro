---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('rahova') ||
    article.slug.toLowerCase().includes('sector-5') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Rahova, Sectorul 5, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Rahova | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Rahova, Sectorul 5, Bucuresti","url":"https://www.superparty.ro/petreceri/rahova"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Activati in Rahova si Ferentari?","acceptedAnswer":{"@type":"Answer","text":"Da — acoperim complet Sectorul 5: Rahova, Ferentari, Sebastian, Cotroceni si toate zonele adiacente. Transport inclus, fara surprize."}},
      {"@type":"Question","name":"Cat costa un animator in Rahova?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 1 porneste de la 490 RON (1 personaj, 2 ore). Nu exista taxa de deplasare in Sectorul 5."}},
      {"@type":"Question","name":"Faceti petreceri si in Parcul Sebastian?","acceptedAnswer":{"@type":"Answer","text":"Da — animatia in aer liber este posibila in Parcul Sebastian. Animatorul vine cu materialele necesare. Ideal pentru grupuri de 15-30 copii."}},
      {"@type":"Question","name":"Sunt disponibili animatorii in Rahova in zilele lucratoare?","acceptedAnswer":{"@type":"Answer","text":"Da — avem disponibilitate dupa 16:00 in zilele de saptamana si toata ziua in weekend."}},
      {"@type":"Question","name":"Ce personaje sunt populare in zona Rahova?","acceptedAnswer":{"@type":"Answer","text":"Spider-Man, Batman, Capitanul America (pentru baieti), Elsa, Rapunzel, Minnie (pentru fete) si Clownul vesnic verde pentru ambele sexe."}},
      {"@type":"Question","name":"Aveti experienta cu petrecerile in apartamente mai mici din Rahova?","acceptedAnswer":{"@type":"Answer","text":"Da — stim sa ne adaptam oricarui spatiu. Un animator poate face un program excelent chiar si intr-un salon de 20-25 mp."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 5","item":"https://www.superparty.ro/petreceri/sector-5"},
      {"@type":"ListItem","position":4,"name":"Rahova","item":"https://www.superparty.ro/petreceri/rahova"}
    ]}
  ]
});
---

<Layout
  title="Animatori Petreceri Copii Rahova Bucuresti | SuperParty — de la 490 RON"
  description="Animatori profesionisti pentru petreceri copii in Rahova, Sectorul 5. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/rahova"
  schema={schema}
>
<style>
  .hero{padding:4.5rem 0 3rem;background:radial-gradient(ellipse at top,rgba(255,107,53,.12) 0%,transparent 60%)}
  .hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;margin-bottom:1rem;line-height:1.2}
  .hero .lead{color:var(--text-muted);font-size:1.05rem;max-width:650px;line-height:1.8;margin-bottom:2rem}
  .btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-p{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;padding:.9rem 2rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;transition:transform .2s}
  .btn-p:hover{transform:translateY(-2px)}
  .btn-wa{background:#25d366;color:#fff;padding:.9rem 1.8rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem}
  .sec{padding:3.5rem 0}.sec-alt{padding:3.5rem 0;background:var(--dark-2)}
  .sec-title{font-size:1.6rem;font-weight:800;margin-bottom:.5rem}.sec-sub{color:var(--text-muted);margin-bottom:2rem}
  .grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
  .card{background:var(--dark-3);border:1px solid rgba(255,107,53,.15);border-radius:14px;padding:1.5rem}
  .card h3{font-weight:700;margin-bottom:.8rem;font-size:1rem}
  .card ul{list-style:none;padding:0;margin:0}
  .card li{padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.88rem;color:var(--text-muted);line-height:1.5}
  .card li:last-child{border:0}
  .pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem}
  .pkg{background:var(--dark-3);border:2px solid rgba(255,107,53,.2);border-radius:18px;padding:2rem;text-align:center}
  .pkg.featured{border-color:var(--primary);background:rgba(255,107,53,.08)}
  .pkg-title{font-size:1.2rem;font-weight:800;margin-bottom:.4rem}
  .pkg-price{font-size:2rem;font-weight:900;color:var(--primary);margin:.5rem 0}
  .pkg-desc{font-size:.88rem;color:var(--text-muted);line-height:1.6}
  .pkg-badge{background:var(--primary);color:#fff;font-size:.7rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;display:inline-block;margin-bottom:.5rem}
  .art-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .art-card{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.2rem;text-decoration:none;color:var(--text);transition:border-color .2s}
  .art-card:hover{border-color:var(--primary)}
  .art-card h3{font-size:.95rem;font-weight:700;color:var(--primary);margin-bottom:.4rem}
  .art-card p{font-size:.82rem;color:var(--text-muted)}
  .faq-list{display:flex;flex-direction:column;gap:1rem;max-width:780px}
  .faq-item{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.4rem}
  .faq-item h3{font-size:.95rem;font-weight:700;margin-bottom:.6rem}
  .faq-item p{font-size:.9rem;color:var(--text-muted);line-height:1.7}
  .breadcrumb{font-size:.82rem;color:var(--text-muted);margin-bottom:1.5rem}
  .breadcrumb a{color:var(--primary);text-decoration:none}
  .cta-box{background:linear-gradient(135deg,rgba(255,107,53,.15),rgba(255,107,53,.05));border:1px solid rgba(255,107,53,.25);border-radius:20px;padding:3rem 2rem;text-align:center}
  .cta-box h2{font-size:1.7rem;font-weight:800;margin-bottom:1rem}
  .cta-box p{color:var(--text-muted);margin-bottom:2rem}
  .nav-links{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-top:1.5rem;font-size:.9rem}
  .nav-links a{color:var(--primary);font-weight:600;text-decoration:none}
  .rich-text{max-width:780px}
  .rich-text p{color:var(--text-muted);line-height:1.9;margin-bottom:1rem}
  .rich-text strong{color:var(--text)}
  @media(max-width:600px){.btns{flex-direction:column}}
</style>

<section class="hero">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Acasa</a> › <a href="/animatori-petreceri-copii">Animatori Petreceri Copii</a> › <a href="/petreceri/sector-5">Sectorul 5</a> › Rahova
    </nav>
    <h1>Animatori Petreceri Copii<br><span style="color:var(--primary)">Rahova, Bucuresti</span></h1>
    <p class="lead">SuperParty este echipa #1 de animatori pentru petreceri copii din <strong>Rahova</strong>, cartier traditional din sudul Bucurestiului, Sectorul 5, cu o comunitate autentica si cu numeroase familii tinere care cauta servicii de animatie accesibile si profesioniste. Peste 10.000 de petreceri din 2018, garantie contractuala unica in piata, 1498 de recenzii de 5 stele.</p>
    <div class="btns">
      <a href="tel:+40722744377" class="btn-p cta">📞 Rezerva: 0722 744 377</a>
      <a href="https://wa.me/40722744377" class="btn-wa cta">💬 WhatsApp rapid</a>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="grid-3">
      <div class="card">
        <h3>📍 Zone si repere Rahova</h3>
        <ul><li>📍 Parcul Sebastian - 20 hectare cu lac si spatii verzi</li>
<li>📍 Calea Rahovei - artera istorica principala</li>
<li>📍 Piata Rahova - piata agro-alimentara traditionala</li>
<li>📍 Sala Sporturilor din Sectorul 5</li>
<li>📍 Gradina Botanica - la 10 minute (vizita recomandata inainte de petrecere)</li></ul>
      </div>
      <div class="card">
        <h3>⏱ Acces si transport</h3>
        <ul>
          <li>🚗 ~20 min din centru</li>
          <li>🚍 Autobuze 385, 382, 226; tramvaie 5, 6; acces via Calea Rahovei</li>
          <li>✅ Animatorul soseste cu 10 min inainte</li>
          <li>✅ Transport gratuit in Rahova</li>
          <li><a href="/petreceri/sector-5" style="color:var(--primary)">→ Toate zonele Sector 5</a></li>
        </ul>
      </div>
      <div class="card">
        <h3>🎉 Sali recomandate Rahova</h3>
        <ul><li>🎉 Sala de petreceri Sebastian Events</li>
<li>🎉 Restaurante cu sali private pe Calea Rahovei</li>
<li>🎉 Centrul de evenimente Sectorul 5</li></ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Pachete animatori <span style="color:var(--primary)">disponibile in Rahova</span></h2>
    <p class="sec-sub">Preturi garantate contractual. Fara taxe ascunse.</p>
    <div class="pkg-grid">
      <div class="pkg">
        <div class="pkg-title">Super 1</div>
        <div class="pkg-price">490 RON</div>
        <div class="pkg-desc">1 personaj costumat · 2 ore<br>Jocuri, baloane, face painting, mini disco<br>Transport gratuit in Rahova</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg featured">
        <div class="pkg-badge">⭐ CEL MAI ALES</div>
        <div class="pkg-title">Super 3</div>
        <div class="pkg-price">840 RON</div>
        <div class="pkg-desc">2 personaje costumati · 2 ore<br>Jocuri duble, baloane complexe, diplome<br>Transport gratuit in Rahova</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg">
        <div class="pkg-title">Super 7</div>
        <div class="pkg-price">1290 RON</div>
        <div class="pkg-desc">1 animator + 4 ursitoare · 3 ore<br>Botez sau aniversare mare<br>Transport gratuit in Rahova</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:1.5rem;color:var(--text-muted);font-size:.9rem">
      <a href="/animatori-petreceri-copii" style="color:var(--primary);font-weight:600">→ Toate detaliile pachetelor pe pagina principala</a>
    </p>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Locatii pentru petreceri copii în <span style="color:var(--primary)">Rahova</span></h2>
    <div class="rich-text">
      <p><strong>Parcul Sebastian</strong> (20 ha) este destinatia de vara preferata pentru familiile din Rahova — zone de picnic accesibile, copaci cu umbra, locuri de joaca. SuperParty organizeaza animatii in Parcul Sebastian fara rezervare prealabila pentru grupuri sub 50 persoane. Animatorul vine cu tot echipamentul portabil.</p>
<p>Pe <strong>Calea Rahovei</strong> gasesti restaurante cu curti si sali private la preturi accesibile: Restaurant Miraj cu gradina, Gradina Rahova, Kronos Events — sali 30-60 persoane cu meniu si sistem audio inclus. Salile de petreceri dedicate copiilor: Fun House Sebastian, Rainbow Kids — cu trambulina si dotari complete.</p>
<p>Casele cu curti din zona Rahova sunt ideale pentru petreceri mari de familie — spatiu generos, aer liber, atmosfera calda. Curtile permit chiar si activitati cu echipament mai mare (trambuline portabile, zone de joaca temporare).</p>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Personaje si teme populare în <span style="color:var(--primary)">Rahova</span></h2>
    <div class="rich-text">
      <p><strong>Personaje top in Rahova:</strong> Spider-Man (dominant), Batman, Captain America, Elsa, Minnie Mouse. Cerere speciala in zona: <strong>Clownul vesel</strong> — personaj interactiv cu magie, ghicitori si umor potrivit pentru toate varstele, de la copii la bunici.</p>
<p>Petrecerile din Rahova au caracter familial extins — vin bunici, unchi, vecini, nu numai copiii de la gradinita. Animatorul SuperParty stie cum sa antreneze toata familia: jocurile de grup cu implicarea parintilor (dans, stafete, karaoke) transforma petrecerea intr-o sarbatoare autentica.</p>
<p>Face painting-ul elaborat este preferat in zona Rahova — animatorul face modele complexe pe fata si maini (balene, tigri, stelute, draci). Copiii asteapta cu nerabdare la rand pentru design-uri creative si unice.</p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Cum organizezi petrecerea perfecta în <span style="color:var(--primary)">Rahova</span></h2>
    <div class="rich-text">
      <p><strong>Trafic:</strong> Calea Rahovei poate fi aglomerata 17-19. Animatorul pleaca cu 30 min rezerva — ajunge la timp garantat. Petrecerile care termina la 17:00 sau incep dupa 19:00 evita traficul complet.</p>
<p><strong>Petreceri mari:</strong> Familiile din Rahova invita adesea 40-60 persoane. Pentru 25+ copii, pachetul Super 3 (2 animatori, 840 RON) este necesar pentru atentie individuala. Super 7 (3 ore, 1290 RON) este ales pentru botezuri si petreceri mari de familie.</p>
<p><strong>Garantia SuperParty:</strong> Daca copiii nu s-au simtit bine, nu platesti — garantit contractual. Plata dupa petrecere, cash sau card. Rezerva minim 2-3 saptamani inainte la 0722 744 377.</p>
    </div>
  </div>
</section>

{hubArticles.length > 0 && (
<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Idei petreceri copii <span style="color:var(--primary)">Rahova</span></h2>
    <p class="sec-sub">Articole si ghiduri utile.</p>
    <div class="art-grid">
      {hubArticles.map(article => (
        <a href={'/petreceri/' + article.slug} class="art-card">
          <h3>{article.data.title}</h3>
          <p>{article.data.description?.slice(0,100)}...</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

