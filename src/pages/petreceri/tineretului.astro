<Layout
  title="Animatori Petreceri Copii Tineretului | SuperParty"
  description="Animatori profesionisti pentru petreceri copii in Tineretului, Sectorul 4. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/tineretului"
  schema={schema}
