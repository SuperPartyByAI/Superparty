import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('tineretului') ||
    article.slug.toLowerCase().includes('sector-4') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Tineretului, Sectorul 4, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Tineretului | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Tineretului, Sectorul 4, Bucuresti","url":"https://www.superparty.ro/petreceri/tineretului"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Faceti animatie in Parcul Tineretului?","acceptedAnswer":{"@type":"Answer","text":"Da — Parcul Tineretului este una din locatiile noastre preferate! Animatorul vine cu tot echipamentul si face un program de 2 ore in aer liber. Ideal pentru grupuri de 20-50 copii."}},
      {"@type":"Question","name":"Cat costa un animator pentru o petrecere la Parcul Tineretului?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 1 (490 RON) este perfect pentru petreceri in aer liber de pana la 20 copii. Super 3 (840 RON) cu 2 personaje este recomandat pentru 30+ copii."}},
      {"@type":"Question","name":"Ce activitati include animatia in parc la Tineretului?","acceptedAnswer":{"@type":"Answer","text":"In parc: jocuri interactive in echipe, tras cu leaganul de personaj, stafete tematice, dans, mini disco, baloane colorate. Plus face painting si diplome magnetice pentru toti copiii."}},
      {"@type":"Question","name":"E nevoie de autorizatie pentru animatia in Parcul Tineretului?","acceptedAnswer":{"@type":"Answer","text":"Nu este nevoie de autorizatie pentru grupuri mici (sub 50 persoane) intr-o zona verde publica. Va recomandam sa verificati si cu administratia parcului."}},
      {"@type":"Question","name":"Cat de aproape de statia de metrou Timpuri Noi faceti petreceri?","acceptedAnswer":{"@type":"Answer","text":"Acoperim toata zona Timpuri Noi, Tineretului, Berceni si Vacaresti. Animatorul vine cu masina proprie direct la locatia ta."}},
      {"@type":"Question","name":"Aveti animatori disponibili duminica dimineata in Tineretului?","acceptedAnswer":{"@type":"Answer","text":"Da — pornim de la 10:00 dimineata in orice zi. Duminica dimineata in Parcul Tineretului este de altfel very populara."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 4","item":"https://www.superparty.ro/petreceri/sector-4"},
      {"@type":"ListItem","position":4,"name":"Tineretului","item":"https://www.superparty.ro/petreceri/tineretului"}
    ]}
  ]
});
