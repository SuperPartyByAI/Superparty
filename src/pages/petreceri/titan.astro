---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('seo-articles');
const hubArticles = allArticles.filter(article =>
  article.data.indexStatus !== 'hold' && (
    article.slug.toLowerCase().includes('titan') ||
    article.slug.toLowerCase().includes('sector-3') ||
    article.slug.toLowerCase().includes('bucuresti')
  )
).slice(0, 12);

const schema = JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {"@type":"LocalBusiness","name":"SuperParty — Animatori Petreceri Copii","telephone":"+40722744377","url":"https://www.superparty.ro","areaServed":{"@type":"Place","name":"Titan, Sectorul 3, Bucuresti"},"priceRange":"490-1290 RON","aggregateRating":{"@type":"AggregateRating","ratingValue":"5.0","reviewCount":"1498"}},
    {"@type":"Service","name":"Animatori Petreceri Copii Titan | SuperParty","provider":{"@type":"LocalBusiness","name":"SuperParty","telephone":"+40722744377"},"areaServed":"Titan, Sectorul 3, Bucuresti","url":"https://www.superparty.ro/petreceri/titan"},
    {"@type":"FAQPage","mainEntity":[
      {"@type":"Question","name":"Veniti la petreceri in Parcul IOR din Titan?","acceptedAnswer":{"@type":"Answer","text":"Da — facem si animatie in aer liber in Parcul IOR. Animatorii vin cu tot materialul: baloane, accesorii face painting, sistem muzical portabil. E ideal pentru grupuri de 15-40 copii."}},
      {"@type":"Question","name":"Cat costa un animator in Titan?","acceptedAnswer":{"@type":"Answer","text":"Pachetul Super 1 (490 RON) include 1 personaj si 2 ore de program complet. Super 3 (840 RON) include 2 personaje si 2 ore. Super 7 (1290 RON) este recomandat pentru petreceri mari sau botezuri."}},
      {"@type":"Question","name":"Ajungeti si la Sun Plaza sau in zona mall-ului?","acceptedAnswer":{"@type":"Answer","text":"Da — acoperim tot Sectorul 3 inclusiv zona Sun Plaza, Dristor, Vitan. Nu exista taxa de deplasare in aceste zone."}},
      {"@type":"Question","name":"Care e programul standard la o petrecere in Titan?","acceptedAnswer":{"@type":"Answer","text":"Animatorul soseste cu 10 minute inainte, incalzeste copiii cu jocuri usoare, continua cu modelare baloane, face painting, mini disco si surprize tematice. Durata: 2 ore (poate fi extinsa)."}},
      {"@type":"Question","name":"Pot rezerva un animator pentru o petrecere de ziua copilului in apartament in Titan?","acceptedAnswer":{"@type":"Answer","text":"Da, venimm la domiciliu. Avem experienta cu petreceri in apartamente, case si curi. Animatorul se acomodeaza oricarui spatiu."}},
      {"@type":"Question","name":"Cat timp inainte trebuie sa rezerv in Titan?","acceptedAnswer":{"@type":"Answer","text":"Recomandam minim 2 saptamani inainte pentru weekend. In sezon (mai-septembrie) rezervarile se ocupa cu 3-4 saptamani inainte."}}
    ]},
    {"@type":"BreadcrumbList","itemListElement":[
      {"@type":"ListItem","position":1,"name":"Acasa","item":"https://www.superparty.ro"},
      {"@type":"ListItem","position":2,"name":"Animatori Petreceri Copii","item":"https://www.superparty.ro/animatori-petreceri-copii"},
      {"@type":"ListItem","position":3,"name":"Sectorul 3","item":"https://www.superparty.ro/petreceri/sector-3"},
      {"@type":"ListItem","position":4,"name":"Titan","item":"https://www.superparty.ro/petreceri/titan"}
    ]}
  ]
});
---

<Layout
  title="Animatori Petreceri Copii Titan Bucuresti | SuperParty — de la 490 RON"
  description="Animatori profesionisti pentru petreceri copii in Titan, Sectorul 3. 50+ personaje, pachete 490-1290 RON, transport gratuit. Tel: 0722 744 377."
  canonical="https://www.superparty.ro/petreceri/titan"
  schema={schema}
>
<style>
  .hero{padding:4.5rem 0 3rem;background:radial-gradient(ellipse at top,rgba(255,107,53,.12) 0%,transparent 60%)}
  .hero h1{font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;margin-bottom:1rem;line-height:1.2}
  .hero .lead{color:var(--text-muted);font-size:1.05rem;max-width:650px;line-height:1.8;margin-bottom:2rem}
  .btns{display:flex;gap:1rem;flex-wrap:wrap}
  .btn-p{background:linear-gradient(135deg,var(--primary),var(--primary-dark));color:#fff;padding:.9rem 2rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem;transition:transform .2s}
  .btn-p:hover{transform:translateY(-2px)}
  .btn-wa{background:#25d366;color:#fff;padding:.9rem 1.8rem;border-radius:50px;font-weight:700;text-decoration:none;display:inline-flex;align-items:center;gap:.5rem}
  .sec{padding:3.5rem 0}.sec-alt{padding:3.5rem 0;background:var(--dark-2)}
  .sec-title{font-size:1.6rem;font-weight:800;margin-bottom:.5rem}.sec-sub{color:var(--text-muted);margin-bottom:2rem}
  .grid-3{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem}
  .card{background:var(--dark-3);border:1px solid rgba(255,107,53,.15);border-radius:14px;padding:1.5rem}
  .card h3{font-weight:700;margin-bottom:.8rem;font-size:1rem}
  .card ul{list-style:none;padding:0;margin:0}
  .card li{padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.88rem;color:var(--text-muted);line-height:1.5}
  .card li:last-child{border:0}
  .pkg-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem}
  .pkg{background:var(--dark-3);border:2px solid rgba(255,107,53,.2);border-radius:18px;padding:2rem;text-align:center}
  .pkg.featured{border-color:var(--primary);background:rgba(255,107,53,.08)}
  .pkg-title{font-size:1.2rem;font-weight:800;margin-bottom:.4rem}
  .pkg-price{font-size:2rem;font-weight:900;color:var(--primary);margin:.5rem 0}
  .pkg-desc{font-size:.88rem;color:var(--text-muted);line-height:1.6}
  .pkg-badge{background:var(--primary);color:#fff;font-size:.7rem;font-weight:700;padding:.2rem .7rem;border-radius:50px;display:inline-block;margin-bottom:.5rem}
  .art-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1rem}
  .art-card{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.2rem;text-decoration:none;color:var(--text);transition:border-color .2s}
  .art-card:hover{border-color:var(--primary)}
  .art-card h3{font-size:.95rem;font-weight:700;color:var(--primary);margin-bottom:.4rem}
  .art-card p{font-size:.82rem;color:var(--text-muted)}
  .faq-list{display:flex;flex-direction:column;gap:1rem;max-width:780px}
  .faq-item{background:var(--dark-3);border:1px solid rgba(255,107,53,.12);border-radius:14px;padding:1.4rem}
  .faq-item h3{font-size:.95rem;font-weight:700;margin-bottom:.6rem}
  .faq-item p{font-size:.9rem;color:var(--text-muted);line-height:1.7}
  .breadcrumb{font-size:.82rem;color:var(--text-muted);margin-bottom:1.5rem}
  .breadcrumb a{color:var(--primary);text-decoration:none}
  .cta-box{background:linear-gradient(135deg,rgba(255,107,53,.15),rgba(255,107,53,.05));border:1px solid rgba(255,107,53,.25);border-radius:20px;padding:3rem 2rem;text-align:center}
  .cta-box h2{font-size:1.7rem;font-weight:800;margin-bottom:1rem}
  .cta-box p{color:var(--text-muted);margin-bottom:2rem}
  .nav-links{display:flex;gap:1.5rem;flex-wrap:wrap;justify-content:center;margin-top:1.5rem;font-size:.9rem}
  .nav-links a{color:var(--primary);font-weight:600;text-decoration:none}
  .rich-text{max-width:780px}
  .rich-text p{color:var(--text-muted);line-height:1.9;margin-bottom:1rem}
  .rich-text strong{color:var(--text)}
  @media(max-width:600px){.btns{flex-direction:column}}
</style>

<section class="hero">
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Acasa</a> › <a href="/animatori-petreceri-copii">Animatori Petreceri Copii</a> › <a href="/petreceri/sector-3">Sectorul 3</a> › Titan
    </nav>
    <h1>Animatori Petreceri Copii<br><span style="color:var(--primary)">Titan, Bucuresti</span></h1>
    <p class="lead">SuperParty este echipa #1 de animatori pentru petreceri copii din <strong>Titan</strong>, cartier vibrant din Sectorul 3, construit in jurul Parcului IOR, unul din cele mai mari si mai iubite parcuri din Bucuresti. Peste 10.000 de petreceri din 2018, garantie contractuala unica in piata, 1498 de recenzii de 5 stele.</p>
    <div class="btns">
      <a href="tel:+40722744377" class="btn-p cta">📞 Rezerva: 0722 744 377</a>
      <a href="https://wa.me/40722744377" class="btn-wa cta">💬 WhatsApp rapid</a>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <div class="grid-3">
      <div class="card">
        <h3>📍 Zone si repere Titan</h3>
        <ul><li>📍 Parcul IOR - 100 hectare de spatiu verde ideal pentru petreceri in aer liber</li>
<li>📍 Centrul Comercial Sun Plaza - unul din cele mai mari malluri din Romania</li>
<li>📍 Sala Polivalenta - in apropiere</li>
<li>📍 Bulevardul Nicolae Grigorescu - artera principala</li>
<li>📍 Lacul Titan - locatie ideala pentru petreceri de vara</li></ul>
      </div>
      <div class="card">
        <h3>⏱ Acces si transport</h3>
        <ul>
          <li>🚗 ~15 min din centru</li>
          <li>🚍 Metrou (statia Titan pe M2), autobuze 116, 131, troleibuze</li>
          <li>✅ Animatorul soseste cu 10 min inainte</li>
          <li>✅ Transport gratuit in Titan</li>
          <li><a href="/petreceri/sector-3" style="color:var(--primary)">→ Toate zonele Sector 3</a></li>
        </ul>
      </div>
      <div class="card">
        <h3>🎉 Sali recomandate Titan</h3>
        <ul><li>🎉 Sun Plaza Events (nivel -1, Sun Plaza)</li>
<li>🎉 Sala de petreceri IOR (langa parc)</li>
<li>🎉 Restaurante cu sali private in zona Titan-Dristor</li></ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Pachete animatori <span style="color:var(--primary)">disponibile in Titan</span></h2>
    <p class="sec-sub">Preturi garantate contractual. Fara taxe ascunse.</p>
    <div class="pkg-grid">
      <div class="pkg">
        <div class="pkg-title">Super 1</div>
        <div class="pkg-price">490 RON</div>
        <div class="pkg-desc">1 personaj costumat · 2 ore<br>Jocuri, baloane, face painting, mini disco<br>Transport gratuit in Titan</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg featured">
        <div class="pkg-badge">⭐ CEL MAI ALES</div>
        <div class="pkg-title">Super 3</div>
        <div class="pkg-price">840 RON</div>
        <div class="pkg-desc">2 personaje costumati · 2 ore<br>Jocuri duble, baloane complexe, diplome<br>Transport gratuit in Titan</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
      <div class="pkg">
        <div class="pkg-title">Super 7</div>
        <div class="pkg-price">1290 RON</div>
        <div class="pkg-desc">1 animator + 4 ursitoare · 3 ore<br>Botez sau aniversare mare<br>Transport gratuit in Titan</div>
        <div style="margin-top:1rem"><a href="tel:+40722744377" class="btn-p cta" style="display:inline-flex;padding:.7rem 1.5rem">📞 Rezerva</a></div>
      </div>
    </div>
    <p style="text-align:center;margin-top:1.5rem;color:var(--text-muted);font-size:.9rem">
      <a href="/animatori-petreceri-copii" style="color:var(--primary);font-weight:600">→ Toate detaliile pachetelor pe pagina principala</a>
    </p>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Locatii pentru petreceri copii în <span style="color:var(--primary)">Titan</span></h2>
    <div class="rich-text">
      <p>Cea mai populara locatie pentru petreceri de copii din Titan este <strong>Sun Plaza Kids Zone</strong>, etaj -1 al mallului Sun Plaza — spatiu dedicat cu zona de joaca, sistem audio si masa de tort. Pentru vara, <strong>Parcul IOR</strong> (105 ha, cu lac) este perfect pentru animatie in aer liber: copiii alerga liber pe iarba, animatorul vine cu boxe portabile si organizaza jocuri interactive. Zona de langa lacul IOR are mese de picnic si copaci pentru umbra.</p>
<p>Pe <strong>Bulevardul Camil Ressu</strong> gasesti sali de petreceri cu preturi corecte: Fun Arena Titan, Party House Titan si Magic Land. Toate au trambulina, sistem audio si capacitate 20-50 copii. Apartamentele din Titan sunt spatioase — sufrageria clasica de 20-25 mp plus hol incap confortabil 15-20 copii activi fara sala dedicata.</p>
<p>Super recomandare locala: <strong>terasele restaurantelor de pe Calea Vacaresti</strong> (zona Vitan) organizeaza petreceri complete cu meniu si sala privata la preturi competitive — ideal pentru familii care vor totul la un loc.</p>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Personaje si teme populare în <span style="color:var(--primary)">Titan</span></h2>
    <div class="rich-text">
      <p>Parintii din Titan comanda cel mai des <strong>Spider-Man</strong> (lider absolut la baieti 4-9 ani), <strong>Elsa</strong> si <strong>Minnie Mouse</strong> pentru fetite, si <strong>Batman</strong> plus <strong>Captain America</strong>. Dupa 7 ani, <strong>Sonic</strong> si personajele din <strong>Minecraft</strong> au explodat in popularitate.</p>
<p>Teme de petrecere populare in Titan 2025: <strong>Supereroi Marvel/DC</strong> (35% din comenzile noastre in zona), <strong>Printese Disney</strong> (28%), <strong>Animale si jungla</strong> pentru sub 4 ani (18%), <strong>Jocuri video</strong> (Minecraft, Roblox) pentru 8-12 ani (19%). Programul SuperParty include intrare dramatica in costum, 5-6 jocuri interactive, modelare baloane, face painting cu vopsele dermatologice, diplome si mini disco — 2 ore complete fara pauza.</p>
<p>Un plus specific zonei Titan: parintii apreciaza personajele <strong>bilingve</strong> (romana-engleza) datorita scolilor internationale din zona Sun Plaza. La cerere, animatorul comunica partial in engleza.</p>
    </div>
  </div>
</section>

<section class="sec">
  <div class="container">
    <h2 class="sec-title">Cum organizezi petrecerea perfecta în <span style="color:var(--primary)">Titan</span></h2>
    <div class="rich-text">
      <p><strong>Intervalul optim:</strong> Sambata 11:00-13:00 sau 15:00-17:00. Duminica 11:00-13:00. Evitati sarbatorile echipei locale (verificati evenimentele din Sun Plaza — mall-ul se aglomereaza si parcarea devine problema).</p>
<p><strong>Cati copii:</strong> Pana la 25 copii — pachetul Super 1 (490 RON, 1 animator). 25-40 copii — Super 3 (840 RON, 2 animatori). Peste 40 — Super 7 (1290 RON, 3 ore, program extins). Transportul este gratuit pentru orice adresa din Titan.</p>
<p><strong>Rezervare:</strong> Minim 2 saptamani inainte. Titan este una din zonele cu cea mai mare cerere din Sectorul 3 — weekendurile se ocupa repede. Garantia contractuala SuperParty: daca copiii nu s-au simtit bine, nu platesti nimic.</p>
    </div>
  </div>
</section>

{hubArticles.length > 0 && (
<section class="sec-alt">
  <div class="container">
    <h2 class="sec-title">Idei petreceri copii <span style="color:var(--primary)">Titan</span></h2>
    <p class="sec-sub">Articole si ghiduri utile.</p>
    <div class="art-grid">
      {hubArticles.map(article => (
        <a href={'/petreceri/' + article.slug} class="art-card">
          <h3>{article.data.title}</h3>
          <p>{article.data.description?.slice(0,100)}...</p>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<section class="sec" itemscope itemtype="https://schema.org/FAQPage">
  <div class="container">
    <h2 class="sec-title">Intrebari frecvente — animatori <span style="color:var(--primary)">Titan</span></h2>
    <div class="faq-list">

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Veniti la petreceri in Parcul IOR din Titan?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Da — facem si animatie in aer liber in Parcul IOR. Animatorii vin cu tot materialul: baloane, accesorii face painting, sistem muzical portabil. E ideal pentru grupuri de 15-40 copii.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Cat costa un animator in Titan?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Pachetul Super 1 (490 RON) include 1 personaj si 2 ore de program complet. Super 3 (840 RON) include 2 personaje si 2 ore. Super 7 (1290 RON) este recomandat pentru petreceri mari sau botezuri.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Ajungeti si la Sun Plaza sau in zona mall-ului?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Da — acoperim tot Sectorul 3 inclusiv zona Sun Plaza, Dristor, Vitan. Nu exista taxa de deplasare in aceste zone.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Care e programul standard la o petrecere in Titan?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Animatorul soseste cu 10 minute inainte, incalzeste copiii cu jocuri usoare, continua cu modelare baloane, face painting, mini disco si surprize tematice. Durata: 2 ore (poate fi extinsa).</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Pot rezerva un animator pentru o petrecere de ziua copilului in apartament in Titan?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Da, venimm la domiciliu. Avem experienta cu petreceri in apartamente, case si curi. Animatorul se acomodeaza oricarui spatiu.</p>
        </div>
      </div>

      <div class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
        <h3 itemprop="name">❓ Cat timp inainte trebuie sa rezerv in Titan?</h3>
        <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
          <p itemprop="text">Recomandam minim 2 saptamani inainte pentru weekend. In sezon (mai-septembrie) rezervarile se ocupa cu 3-4 saptamani inainte.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="sec-alt">
  <div class="container">
    <div class="cta-box">
      <h2>Rezerva animator în <span style="color:var(--primary)">Titan</span></h2>
      <p>⚡ Disponibilitate limitata in weekend — locurile se ocupa rapid!<br>Garantie contractuala: daca copiii nu s-au simtit bine, nu platesti!</p>
      <div class="btns" style="justify-content:center">
        <a href="tel:+40722744377" class="btn-p cta">📞 0722 744 377</a>
        <a href="https://wa.me/40722744377" class="btn-wa cta">💬 WhatsApp</a>
      </div>
      <nav class="nav-links">
        <a href="/petreceri/sector-3">← Sectorul 3</a>
        <a href="/animatori-petreceri-copii">🎭 Toate pachetele</a>
        <a href="/petreceri/bucuresti">🏙️ Animatori Bucuresti</a>
      </nav>
    </div>
  </div>
</section>

</Layout>