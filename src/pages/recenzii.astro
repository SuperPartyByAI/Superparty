---
import Layout from '../layouts/Layout.astro';
import reviewsRaw from '../data/superparty_testimonials.json';
import { normalizeReview, processReview } from '../lib/text/normalizeReview';

type Review = { siteId: string; slug: string; name: string; location: string; event: string; text: string; source: string; date: string; };
const allReviews = (reviewsRaw as Review[]).filter(r => r.siteId === 'superparty');

// Sort by date (recent first)
const sorted = [...allReviews].sort((a, b) => {
  if (!a.date && !b.date) return 0;
  if (!a.date) return 1;
  if (!b.date) return -1;
  return b.date.localeCompare(a.date);
});

const totalCount = sorted.length;

const CANONICAL = 'https://www.superparty.ro/recenzii/';
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "name": `Recenzii SuperParty — ${totalCount}+ testimoniale reale`,
      "description": `Citește ${totalCount}+ recenzii reale de la părinți care au ales SuperParty pentru petrecerile copiilor lor.`,
      "url": CANONICAL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Acasă", "item": "https://www.superparty.ro" },
        { "@type": "ListItem", "position": 2, "name": "Recenzii", "item": CANONICAL }
      ]
    }
  ]
});

function sourceIcon(src: string) {
  if (src === 'google') return '🟢';
  if (src === 'facebook') return '🔵';
  if (src === 'whatsapp') return '💬';
  return '⭐';
}
function sourceLabel(src: string) {
  const labels: Record<string, string> = { google: 'Google', facebook: 'Facebook', whatsapp: 'WhatsApp' };
  return labels[src] || 'Client';
}

const WA_TEXT = encodeURIComponent('Bună! Am citit recenziile și vreau să rez animatori.\nData: \nLocalitate/Sector: \nVârsta copilului: \nNr. copii: ');
const WA_URL = `https://wa.me/40722744377?text=${WA_TEXT}`;
---

<Layout
  title={`Recenzii SuperParty — ${totalCount}+ testimoniale reale de la părinți`}
  description={`Citește ${totalCount}+ recenzii reale de la părinți care au ales SuperParty. Animatori petreceri copii București și Ilfov.`}
  canonical={CANONICAL}
  schema={schema}
>

<style>
  .rec-hero { padding: 3rem 0 2rem; text-align: center; background: radial-gradient(ellipse at top, rgba(255,107,53,0.1) 0%, transparent 60%); }
  .rec-hero h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 0.75rem; }
  .rec-hero p { color: var(--text-muted); font-size: 1.05rem; margin-bottom: 1.5rem; }
  .stats-bar { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .stat-item { text-align: center; }
  .stat-num { font-size: 1.8rem; font-weight: 800; color: var(--primary); }
  .stat-label { font-size: 0.82rem; color: var(--text-muted); }
  .filter-bar { padding: 1.5rem 0; background: var(--dark-2); border-bottom: 1px solid rgba(255,107,53,0.1); }
  .filter-inner { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; }
  .filter-label { font-size: 0.85rem; color: var(--text-muted); font-weight: 600; }
  .filter-btn {
    background: var(--dark-3); border: 1px solid rgba(255,255,255,0.1);
    color: var(--text-muted); padding: 0.4rem 1rem; border-radius: 20px;
    cursor: pointer; font-size: 0.85rem; transition: all 0.2s; font-family: inherit;
  }
  .filter-btn:hover, .filter-btn.active { background: var(--primary); color: white; border-color: var(--primary); }
  .search-wrap { margin-left: auto; }
  .search-input {
    background: var(--dark-3); border: 1px solid rgba(255,107,53,0.2);
    color: var(--text); padding: 0.4rem 1rem; border-radius: 20px;
    font-size: 0.85rem; outline: none; width: 200px; font-family: inherit;
  }
  .search-input:focus { border-color: var(--primary); }
  .reviews-section { padding: 2.5rem 0 4rem; }
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .review-card {
    background: var(--dark-3); border: 1px solid rgba(255,107,53,0.1);
    border-radius: 14px; padding: 1.2rem; position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  .review-card:hover { border-color: rgba(255,107,53,0.3); transform: translateY(-2px); }
  .review-card[data-hidden="true"] { display: none; }
  .review-text { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 0.8rem; }
  .review-meta { display: flex; align-items: center; gap: 0.4rem; font-size: 0.8rem; }
  .src-badge { font-size: 0.9rem; }
  .src-label { color: var(--text-muted); font-size: 0.78rem; }
  .review-name { font-weight: 700; color: var(--text); }
  .review-loc { color: var(--text-muted); }
  .review-date { color: var(--text-muted); font-size: 0.75rem; margin-left: auto; }
  .event-tag { font-size: 0.76rem; background: rgba(255,107,53,0.1); color: var(--primary); padding: 0.15rem 0.5rem; border-radius: 12px; display: inline-block; margin-top: 0.4rem; }
  .load-more-wrap { text-align: center; margin-top: 2rem; }
  .load-more-btn {
    background: var(--dark-3); border: 2px solid var(--primary); color: var(--primary);
    padding: 0.75rem 2rem; border-radius: 50px; cursor: pointer; font-weight: 700;
    font-size: 0.95rem; transition: all 0.2s; font-family: inherit;
  }
  .load-more-btn:hover { background: var(--primary); color: white; }
  .no-results { text-align: center; color: var(--text-muted); padding: 3rem; }
  .cta-strip {
    background: linear-gradient(135deg, rgba(255,107,53,0.15), rgba(255,107,53,0.05));
    border: 1px solid rgba(255,107,53,0.2); border-radius: 20px;
    padding: 2.5rem 2rem; text-align: center; margin-top: 3rem;
  }
  .cta-strip h2 { font-size: 1.5rem; font-weight: 800; margin-bottom: 0.5rem; }
  .cta-strip p { color: var(--text-muted); margin-bottom: 1.5rem; }
  .cta-btns { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .btn-call { background: var(--primary); color: white; padding: 0.85rem 1.8rem; border-radius: 50px; font-weight: 700; text-decoration: none; }
  .btn-wa { background: #25d366; color: white; padding: 0.85rem 1.8rem; border-radius: 50px; font-weight: 700; text-decoration: none; }
  @media (max-width: 600px) {
    .filter-inner { gap: 0.4rem; }
    .search-wrap { margin-left: 0; width: 100%; }
    .search-input { width: 100%; }
  }
</style>

<!-- Hero -->
<section class="rec-hero">
  <div class="container">
    <h1>Recenzii <span style="color:var(--primary)">Reale</span></h1>
    <p>Testimoniale de la părinți care au ales SuperParty pentru petrecerile copiilor lor</p>
    <div class="stats-bar">
      <div class="stat-item">
        <div class="stat-num">{totalCount}+</div>
        <div class="stat-label">Recenzii reale</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">8.000+</div>
        <div class="stat-label">Petreceri organizate</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">🟢🔵💬</div>
        <div class="stat-label">Google · Facebook · WhatsApp</div>
      </div>
    </div>
  </div>
</section>

<!-- Filter + Search -->
<div class="filter-bar">
  <div class="container">
    <div class="filter-inner">
      <span class="filter-label">Filtrează:</span>
      <button class="filter-btn active" data-filter="all" id="filter-all">Toate</button>
      <button class="filter-btn" data-filter="București">București</button>
      <button class="filter-btn" data-filter="Sector 1">Sector 1</button>
      <button class="filter-btn" data-filter="Sector 2">Sector 2</button>
      <button class="filter-btn" data-filter="Sector 3">Sector 3</button>
      <button class="filter-btn" data-filter="Sector 4">Sector 4</button>
      <button class="filter-btn" data-filter="Sector 5">Sector 5</button>
      <button class="filter-btn" data-filter="Sector 6">Sector 6</button>
      <div class="search-wrap">
        <input type="text" id="rec-search" class="search-input" placeholder="Caută în recenzii..." aria-label="Cauta in recenzii"/>
      </div>
    </div>
  </div>
</div>

<!-- Reviews Grid -->
<section class="reviews-section">
  <div class="container">
    <div class="reviews-grid" id="reviews-grid">
      {sorted.map((r, idx) => {
        const name     = normalizeReview(r.name || '');
        const loc      = normalizeReview(r.location || '');
        const event    = normalizeReview(r.event || '');
        const text     = processReview(r.text || '');
        return (
        <article
          class="review-card"
          data-loc={loc}
          data-text={text.toLowerCase()}
          data-idx={idx}
          data-hidden={idx >= 24 ? 'true' : 'false'}
        >
          <p class="review-text">"{text}"</p>
          <div class="review-meta">
            <span class="src-badge" title={sourceLabel(r.source)}>{sourceIcon(r.source)}</span>
            <span class="review-name">{name}</span>
            {loc && <span class="review-loc">· {loc}</span>}
            {r.date && <span class="review-date">{r.date.slice(0, 7)}</span>}
          </div>
          {event && <span class="event-tag">{event}</span>}
        </article>
        );
      })}
    </div>
    <p class="no-results" id="no-results" style="display:none">Nu s-au găsit recenzii pentru acest filtru.</p>
    <div class="load-more-wrap" id="load-more-wrap">
      <button class="load-more-btn" id="load-more-btn">+ Afișează mai multe recenzii</button>
    </div>
    <!-- CTA -->
    <div class="cta-strip">
      <h2>Vreau și eu o petrecere ca în recenzii! 🎉</h2>
      <p>Sună sau scrie pe WhatsApp — verificăm disponibilitatea și trimitem oferta</p>
      <div class="cta-btns">
        <a href="tel:+40722744377" class="btn-call cta">📞 0722 744 377</a>
        <a href={WA_URL} class="btn-wa cta" target="_blank" rel="noopener noreferrer">💬 WhatsApp</a>
      </div>
      <p style="margin-top:1rem;font-size:.9rem;color:var(--text-muted);">
        ← <a href="/animatori-petreceri-copii/" style="color:var(--primary);font-weight:600;">Animatori Petreceri Copii</a>
      </p>
    </div>
  </div>
</section>

<script>
  (function() {
    var PAGE_SIZE = 24;
    var currentPage = 1;
    var currentFilter = 'all';
    var currentSearch = '';

    var grid = document.getElementById('reviews-grid');
    var cards = grid ? Array.from(grid.querySelectorAll('.review-card')) as HTMLElement[] : [];
    var noResults = document.getElementById('no-results');
    var loadMoreWrap = document.getElementById('load-more-wrap');
    var loadMoreBtn = document.getElementById('load-more-btn');

    function applyFilters() {
      var visible = 0;
      var shown = 0;
      var limit = currentPage * PAGE_SIZE;
      cards.forEach(function(card) {
        var loc = (card.dataset.loc || '').toLowerCase();
        var txt = (card.dataset.text || '').toLowerCase();
        var matchFilter = currentFilter === 'all' || loc.includes(currentFilter.toLowerCase());
        var matchSearch = !currentSearch || txt.includes(currentSearch) || loc.includes(currentSearch);
        if (matchFilter && matchSearch) {
          visible++;
          if (shown < limit) { card.dataset.hidden = 'false'; card.style.display = ''; shown++; }
          else { card.dataset.hidden = 'true'; card.style.display = 'none'; }
        } else {
          card.dataset.hidden = 'true'; card.style.display = 'none';
        }
      });
      if (noResults) noResults.style.display = visible === 0 ? '' : 'none';
      if (loadMoreWrap) loadMoreWrap.style.display = visible > limit ? '' : 'none';
    }

    // Filter buttons
    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentFilter = (btn as HTMLElement).dataset.filter || 'all';
        currentPage = 1;
        applyFilters();
      });
    });

    // Search
    var searchInput = document.getElementById('rec-search');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        currentSearch = (this as HTMLInputElement).value.toLowerCase().trim();
        currentPage = 1;
        applyFilters();
      });
    }

    // Load more
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', function() {
        currentPage++;
        applyFilters();
      });
    }

    applyFilters();
  })();
</script>

</Layout>
